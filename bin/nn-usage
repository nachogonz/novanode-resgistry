#!/usr/bin/env bash

VERSION="1.0.4"
SUMMARY_TSV=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat << EOF
nn-usage ${VERSION}

AI token usage status CLI for Claude, Codex and Cursor.

Usage:
  nn-usage
  nn-usage --help
  nn-usage --version

Environment:
  AI_USAGE_PLAN_PRICE_USD          Base plan price used for spending totals
  AI_USAGE_CLAUDE_CUSTOM_SPEND_USD Extra Claude spend to include
  AI_USAGE_CODEX_CUSTOM_SPEND_USD  Extra Codex spend to include
  AI_USAGE_CURSOR_CUSTOM_SPEND_USD Extra Cursor spend to include
  AI_USAGE_NO_REFRESH_PROMPT=1     Skip interactive provider refresh prompt
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  -v|--version)
    echo "$VERSION"
    exit 0
    ;;
  --summary-tsv)
    SUMMARY_TSV=1
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1" >&2
    echo "Run 'nn-usage --help' for usage." >&2
    exit 2
    ;;
esac

# ─── Shared helpers ───────────────────────────────────────────────────────────
bar() {
  python3 - "$1" "$2" << 'PYEOF'
import sys
p = max(0, min(float(sys.argv[1] or 0), 100))
w = int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[2] else 22
f = round((p / 100) * w)
print("█" * f + "░" * (w - f))
PYEOF
}

table_bar() { bar "$1" "${AI_USAGE_BAR_W:-22}"; }

num_or_zero() {
  local v="$1"
  if [ "$v" = "n/a" ] || [ "$v" = "stale" ] || [ "$v" = "—" ] || [ -z "$v" ]; then
    echo "0"
  else
    echo "$v" | sed 's/%//'
  fi
}

AI_USAGE_PLAN_PRICE_USD="${AI_USAGE_PLAN_PRICE_USD:-20}"
AI_USAGE_CLAUDE_CUSTOM_SPEND_USD="${AI_USAGE_CLAUDE_CUSTOM_SPEND_USD:-2.5}"
AI_USAGE_CODEX_CUSTOM_SPEND_USD="${AI_USAGE_CODEX_CUSTOM_SPEND_USD:-0}"

codex_refresh() {
  local done_file rc=0 spin_pid
  done_file=$(mktemp "${TMPDIR:-/tmp}/ai-usage-codex-refresh.XXXXXX")

  (
    frames='⣾ ⣽ ⣻ ⢿ ⡿ ⣟ ⣯ ⣷'
    while [ ! -s "$done_file" ]; do
      for f in $frames; do
        [ -s "$done_file" ] && break
        printf '\r\033[2K%s  Refreshing Codex...' "$f" >&2
        sleep 0.08
      done
    done
    printf '\r\033[2K' >&2
  ) &
  spin_pid=$!

  python3 - >/dev/null 2>&1 <<'PYEOF' || rc=$?
import json, subprocess, sys, time

try:
    p = subprocess.Popen(
        ["codex", "app-server", "--stdio"],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
except Exception:
    sys.exit(1)

req = (
    '{"jsonrpc":"2.0","id":1,"method":"initialize",'
    '"params":{"clientInfo":{"name":"nn-usage","version":"1.0.7"}}}\n'
    '{"jsonrpc":"2.0","id":2,"method":"account/rateLimits/read","params":{}}\n'
)
ok = False
try:
    p.stdin.write(req)
    p.stdin.flush()
    deadline = time.time() + 8
    while time.time() < deadline:
        line = p.stdout.readline()
        if not line:
            break
        line = line.strip()
        if not line.startswith("{"):
            continue
        try:
            msg = json.loads(line)
        except Exception:
            continue
        if msg.get("id") == 2:
            ok = "result" in msg
            break
finally:
    try:
        p.kill()
    except Exception:
        pass
    try:
        p.wait(timeout=1)
    except Exception:
        pass

sys.exit(0 if ok else 1)
PYEOF

  echo done > "$done_file"
  wait "$spin_pid" 2>/dev/null
  rm -f "$done_file"

  if [ "$rc" -ne 0 ]; then
    echo "Codex refresh failed. Run 'codex' manually to reconnect." >&2
  fi
  return "$rc"
}

refresh_after_unlock() {
  [ -t 0 ] && [ -t 1 ] || return 0
  [ "${AI_USAGE_NO_REFRESH_PROMPT:-0}" = "1" ] && return 0

  local claude_needs="$1"
  local codex_needs="$2"
  local options prompt key

  if [ "$claude_needs" != "1" ] && [ "$codex_needs" != "1" ]; then
    return 0
  fi

  echo
  echo "Usage snapshot needs a provider refresh."
  options="[enter] skip"
  if [ "$codex_needs" = "1" ]; then options="[c] Codex  ${options}"; fi
  if [ "$claude_needs" = "1" ]; then options="[a] Claude  ${options}"; fi
  if [ "$claude_needs" = "1" ] && [ "$codex_needs" = "1" ]; then options="[r] both  ${options}"; fi
  prompt="Refresh now? ${options}: "

  printf "%s" "$prompt"
  IFS= read -r -s -n 1 key || key=""
  echo

  case "$key" in
    c|C)
      [ "$codex_needs" = "1" ] && codex_refresh
      ;;
    a|A)
      [ "$claude_needs" = "1" ] && claude
      ;;
    r|R)
      if [ "$codex_needs" = "1" ]; then
        codex_refresh
      fi
      if [ "$claude_needs" = "1" ]; then
        claude
      fi
      ;;
    *)
      return 0
      ;;
  esac

  # Replace the current dashboard in place after a refresh. Clearing both the
  # viewport and scrollback avoids stacking a second copy below stale data.
  if [ -t 1 ]; then
    printf '\033[H\033[2J\033[3J'
  fi
  AI_USAGE_NO_REFRESH_PROMPT=1 exec "$0"
}

start_loading() {
  [ -t 2 ] || return 0
  LOADING_DONE_FILE=$(mktemp "${TMPDIR:-/tmp}/ai-usage-loading.XXXXXX")
  (
    frames='⣾ ⣽ ⣻ ⢿ ⡿ ⣟ ⣯ ⣷'
    set -- $frames
    i=1
    while [ ! -f "$LOADING_DONE_FILE" ]; do
      printf '\r\033[2K%s  Loading AI usage...' "$1" >&2
      shift
      [ $# -eq 0 ] && set -- $frames
      i=$((i + 1))
      sleep 0.08
    done
    printf '\r\033[2K' >&2
  ) &
  LOADING_PID=$!
}

stop_loading() {
  [ -n "${LOADING_DONE_FILE:-}" ] && : > "$LOADING_DONE_FILE" 2>/dev/null
  [ -n "${LOADING_PID:-}" ] && wait "$LOADING_PID" 2>/dev/null
  [ -n "${LOADING_DONE_FILE:-}" ] && rm -f "$LOADING_DONE_FILE" 2>/dev/null
}

trap 'stop_loading; rm -f "$CLAUDE_TMP" "$CURSOR_TMP" "$CODEX_TMP" 2>/dev/null' EXIT

if [ "$SUMMARY_TSV" != "1" ]; then
  start_loading
fi

CLAUDE_STATUSLINE_INPUT=""
if [ ! -t 0 ]; then
  CLAUDE_STATUSLINE_INPUT=$(cat)
fi

# ─── Fetch providers in parallel ──────────────────────────────────────────────
CLAUDE_TMP=$(mktemp "${TMPDIR:-/tmp}/ai-usage-claude.XXXXXX")
CURSOR_TMP=$(mktemp "${TMPDIR:-/tmp}/ai-usage-cursor.XXXXXX")
CODEX_TMP=$(mktemp "${TMPDIR:-/tmp}/ai-usage-codex.XXXXXX")

(
CLAUDE_STATUSLINE_INPUT="$CLAUDE_STATUSLINE_INPUT" python3 << 'PYEOF' > "$CLAUDE_TMP"
import glob, json, os, re, subprocess, time, urllib.error, urllib.request
from datetime import datetime, timedelta, timezone
from zoneinfo import ZoneInfo

def bar(percent, w=22):
    try:
        p = max(0, min(float(percent), 100)) / 100
    except Exception:
        p = 0
    f = round(p * w)
    return "█" * f + "░" * (w - f)

def fmt_time(value):
    if value is None:
        return "n/a"
    try:
        if isinstance(value, (int, float)):
            ts = float(value)
            if ts > 1e12:
                ts /= 1000.0
            dt = datetime.fromtimestamp(ts, timezone.utc)
        else:
            text = str(value).strip()
            if not text:
                return "n/a"
            if text.endswith("Z"):
                text = text[:-1] + "+00:00"
            dt = datetime.fromisoformat(text)
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=timezone.utc)
        local = dt.astimezone(ZoneInfo("America/Argentina/Buenos_Aires"))
        return local.strftime("%H:%M")
    except Exception:
        return "n/a"

def fmt_week(value):
    if value is None:
        return "n/a"
    try:
        if isinstance(value, (int, float)):
            ts = float(value)
            if ts > 1e12:
                ts /= 1000.0
            dt = datetime.fromtimestamp(ts, timezone.utc)
        else:
            text = str(value).strip()
            if not text:
                return "n/a"
            if text.endswith("Z"):
                text = text[:-1] + "+00:00"
            dt = datetime.fromisoformat(text)
            if dt.tzinfo is None:
                dt = dt.replace(tzinfo=timezone.utc)
        local = dt.astimezone(ZoneInfo("America/Argentina/Buenos_Aires"))
        return local.strftime("%-d %b")
    except Exception:
        return "n/a"

def fmt_pct(value):
    try:
        return f"{float(value):.0f}"
    except Exception:
        return "n/a"

def emit(five_pct, five_reset, week_pct, week_reset):
    print(f"{bar(five_pct)}|{fmt_pct(five_pct)}|{five_reset or 'n/a'}")
    print(f"{bar(week_pct)}|{fmt_pct(week_pct)}|{week_reset or 'n/a'}")

CACHE_PATH = os.path.expanduser("~/.cache/ai-usage/claude-usage.json")
CACHE_TTL = 120
CACHE_REFRESH = 30

def cache_age():
    try:
        with open(CACHE_PATH) as fh:
            return time.time() - json.load(fh).get("fetched_at", 0)
    except Exception:
        return None

def load_cache(allow_stale=False):
    try:
        with open(CACHE_PATH) as fh:
            cached = json.load(fh)
        age = time.time() - cached.get("fetched_at", 0)
        if allow_stale or age <= CACHE_TTL:
            return cached.get("usage")
    except Exception:
        pass
    return None

def save_cache(usage):
    try:
        os.makedirs(os.path.dirname(CACHE_PATH), exist_ok=True)
        with open(CACHE_PATH, "w") as fh:
            json.dump({"fetched_at": time.time(), "usage": usage}, fh)
    except Exception:
        pass

def usage_from_payload(usage):
    five = usage.get("five_hour") or {}
    week = usage.get("seven_day") or {}
    limits = usage.get("limits") or []
    five_pct = five.get("utilization")
    week_pct = week.get("utilization")
    five_reset = five.get("resets_at")
    week_reset = week.get("resets_at")
    for item in limits:
        kind = item.get("kind")
        if kind == "session" and five_pct is None:
            five_pct = item.get("percent")
            five_reset = five_reset or item.get("resets_at")
        if kind == "weekly_all" and week_pct is None:
            week_pct = item.get("percent")
            week_reset = week_reset or item.get("resets_at")
    return (
        five_pct if five_pct is not None else 0,
        fmt_time(five_reset),
        week_pct if week_pct is not None else 0,
        fmt_week(week_reset),
    )

def fetch_oauth_usage():
    age = cache_age()
    if age is not None and age <= CACHE_REFRESH:
        return load_cache()

    try:
        raw = subprocess.check_output(
            ["security", "find-generic-password", "-s", "Claude Code-credentials", "-w"],
            stderr=subprocess.DEVNULL,
            text=True,
        )
        creds = json.loads(raw)
        token = creds.get("claudeAiOauth", {}).get("accessToken")
        if not token:
            return None
        try:
            version = subprocess.check_output(["claude", "--version"], stderr=subprocess.DEVNULL, text=True).strip().split()[0]
        except Exception:
            version = "0.0.0"
        req = urllib.request.Request(
            "https://api.anthropic.com/api/oauth/usage",
            headers={
                "Authorization": f"Bearer {token}",
                "anthropic-beta": "oauth-2025-04-20",
                "User-Agent": f"claude-code/{version}",
                "Accept": "application/json",
            },
            method="GET",
        )
        with urllib.request.urlopen(req, timeout=6) as resp:
            usage = json.loads(resp.read().decode("utf-8"))
            save_cache(usage)
            return usage
    except Exception:
        return load_cache(allow_stale=True)

def from_statusline():
    statusline_raw = os.environ.get("CLAUDE_STATUSLINE_INPUT", "").strip()
    if not statusline_raw:
        return None
    try:
        statusline = json.loads(statusline_raw)
        rate_limits = statusline.get("rate_limits") or statusline.get("rateLimits") or {}
        primary = rate_limits.get("primary") or rate_limits.get("five_hour") or {}
        secondary = rate_limits.get("secondary") or rate_limits.get("seven_day") or {}
        five_pct = primary.get("used_percentage")
        week_pct = secondary.get("used_percentage")
        if five_pct is None and week_pct is None:
            return None
        return (
            five_pct if five_pct is not None else 0,
            fmt_time(primary.get("resets_at")),
            week_pct if week_pct is not None else 0,
            fmt_week(secondary.get("resets_at")),
        )
    except Exception:
        return None

def parse_reset_text(text, event_ts, weekly=False):
    if not text or event_ts is None:
        return None
    clean = re.sub(r"\s*\([^)]*\)", "", str(text)).strip()
    tz_name = "America/Argentina/Buenos_Aires"
    tz_match = re.search(r"\(([^)]+)\)", str(text))
    if tz_match:
        tz_name = tz_match.group(1)
    try:
        tz = ZoneInfo(tz_name)
    except Exception:
        tz = ZoneInfo("America/Argentina/Buenos_Aires")
    try:
        event_text = str(event_ts).strip()
        if event_text.endswith("Z"):
            event_text = event_text[:-1] + "+00:00"
        base = datetime.fromisoformat(event_text).astimezone(tz)
    except Exception:
        return None
    try:
        if weekly:
            m = re.search(r"([A-Za-z]{3}\s+\d{1,2}).*?(\d{1,2}(?::\d{2})?\s*(?:am|pm)?)", clean, re.I)
            if not m:
                return None
            month_day = m.group(1)
            clock = re.sub(r"\s+", "", m.group(2).lower())
            for fmt in ("%b %d %I:%M%p", "%b %d %I%p"):
                try:
                    return datetime.strptime(f"{month_day} {clock}", fmt).replace(year=base.year, tzinfo=tz)
                except Exception:
                    continue
        else:
            m = re.search(r"(\d{1,2}:\d{2}\s*(?:am|pm)?|\d{1,2}\s*(?:am|pm))", clean, re.I)
            if not m:
                return None
            clock = re.sub(r"\s+", "", m.group(1).lower())
            for fmt in ("%I:%M%p", "%I%p"):
                try:
                    dt = datetime.strptime(clock, fmt).replace(
                        year=base.year, month=base.month, day=base.day, tzinfo=tz
                    )
                    if dt < base:
                        dt += timedelta(days=1)
                    return dt
                except Exception:
                    continue
    except Exception:
        return None
    return None

def extract_limit_text(content):
    if isinstance(content, list):
        for part in content:
            if isinstance(part, dict) and part.get("type") == "text":
                return part.get("text", "")
    if isinstance(content, str):
        return content
    return ""

def reset_label_from_text(text):
    m = re.search(r"resets\s+(.+?)(?:\s*\(|$)", text, re.I)
    return m.group(1).strip() if m else None

def from_logs():
    now = datetime.now(timezone.utc)
    latest_five = None
    latest_weekly = None
    latest_five_util = None
    latest_week_util = None
    paths = glob.glob(os.path.expanduser("~/Library/Application Support/Claude/local-agent-mode-sessions/**/*.jsonl"), recursive=True)
    for path in paths:
        try:
            with open(path, errors="ignore") as fh:
                for line in fh:
                    try:
                        d = json.loads(line)
                    except Exception:
                        continue
                    info = d.get("rate_limit_info") if d.get("type") == "rate_limit_event" else None
                    if info:
                        util = info.get("utilization")
                        reset_raw = info.get("resetsAt")
                        rate_type = info.get("rateLimitType")
                        if util is not None and rate_type == "five_hour":
                            latest_five_util = (float(util) * 100 if float(util) <= 1 else float(util), reset_raw)
                        if util is not None and rate_type == "seven_day":
                            latest_week_util = (float(util) * 100 if float(util) <= 1 else float(util), reset_raw)
                    text = extract_limit_text(d.get("message", {}).get("content", ""))
                    lower = text.lower()
                    if "weekly limit" in lower:
                        reset_dt = parse_reset_text(text, d.get("timestamp"), True)
                        reset_label = reset_label_from_text(text)
                        if reset_dt and reset_dt > now.astimezone(reset_dt.tzinfo) and (latest_weekly is None or reset_dt > latest_weekly[0]):
                            latest_weekly = (reset_dt, {"utilization": 1.0, "resetsAtText": reset_label})
                    if "session limit" in lower:
                        reset_dt = parse_reset_text(text, d.get("timestamp"), False)
                        reset_label = reset_label_from_text(text)
                        if reset_dt and reset_dt > now.astimezone(reset_dt.tzinfo) and (latest_five is None or reset_dt > latest_five[0]):
                            latest_five = (reset_dt, {"utilization": 1.0, "resetsAtText": reset_label})
        except Exception:
            pass

    paths = glob.glob(os.path.expanduser("~/.claude/projects/**/*.jsonl"), recursive=True)
    for path in paths[-20:]:
        try:
            with open(path, errors="ignore") as fh:
                for line in fh:
                    try:
                        d = json.loads(line)
                    except Exception:
                        continue
                    if d.get("error") != "rate_limit":
                        continue
                    text = extract_limit_text(d.get("message", {}).get("content", ""))
                    lower = text.lower()
                    if "weekly limit" in lower:
                        reset_dt = parse_reset_text(text, d.get("timestamp"), True)
                        reset_label = reset_label_from_text(text)
                        if reset_dt and reset_dt > now.astimezone(reset_dt.tzinfo) and (latest_weekly is None or reset_dt > latest_weekly[0]):
                            latest_weekly = (reset_dt, {"utilization": 1.0, "resetsAtText": reset_label})
                    if "session limit" in lower:
                        reset_dt = parse_reset_text(text, d.get("timestamp"), False)
                        reset_label = reset_label_from_text(text)
                        if reset_dt and reset_dt > now.astimezone(reset_dt.tzinfo) and (latest_five is None or reset_dt > latest_five[0]):
                            latest_five = (reset_dt, {"utilization": 1.0, "resetsAtText": reset_label})
        except Exception:
            pass

    def pct_from(item, util_item):
        if util_item:
            pct = util_item[0]
            reset = fmt_time(util_item[1]) if util_item[1] is not None else "n/a"
            return pct, reset
        if not item:
            return None, "n/a"
        info = item[1]
        util = info.get("utilization")
        if util is not None:
            pct = float(util) * 100 if float(util) <= 1 else float(util)
            return pct, info.get("resetsAtText") or fmt_time(info.get("resetsAt"))
        if info.get("resetsAtText"):
            return 100.0, info.get("resetsAtText")
        if info.get("resetsAt"):
            return 100.0, fmt_time(info.get("resetsAt"))
        return None, "n/a"

    five_pct, five_reset = pct_from(latest_five, latest_five_util)
    week_pct, week_reset = pct_from(latest_weekly, latest_week_util)
    if five_pct is None and week_pct is None:
        return None
    return (
        five_pct if five_pct is not None else 0,
        five_reset,
        week_pct if week_pct is not None else 0,
        week_reset,
    )

usage = fetch_oauth_usage()
if usage:
    emit(*usage_from_payload(usage))
    raise SystemExit

cached = load_cache(allow_stale=True)
if cached:
    emit(*usage_from_payload(cached))
    raise SystemExit

statusline = from_statusline()
if statusline:
    emit(*statusline)
    raise SystemExit

logs = from_logs()
if logs:
    emit(*logs)
    raise SystemExit

emit(0, "n/a", 0, "n/a")
PYEOF
) &

(
python3 << 'PYEOF' > "$CURSOR_TMP"
import sqlite3, json, os, urllib.request
from datetime import datetime

db = os.path.expanduser('~/Library/Application Support/Cursor/User/globalStorage/state.vscdb')

def fmt_money(cents):
    if cents is None:
        return "n/a"
    return f"${cents / 100:.2f}"

def fmt_pct(n):
    if n is None:
        return "n/a"
    return f"{float(n):.1f}%"

def bar(percent, w=22):
    p = max(0, min(float(percent or 0) / 100, 1))
    f = int(p * w)
    return "█" * f + "░" * (w - f)

def fmt_date(ms):
    try:
        return datetime.fromtimestamp(int(ms) / 1000).strftime("%b %d")
    except Exception:
        return "n/a"

try:
    conn = sqlite3.connect(db)
    cur  = conn.cursor()
    def get(k):
        cur.execute('SELECT value FROM ItemTable WHERE key=?',(k,))
        r = cur.fetchone()
        return r[0].strip('"') if r else ''
    plan   = get('cursorAuth/stripeMembershipType')
    status = get('cursorAuth/stripeSubscriptionStatus')
    raw    = get('cursorAuth/cachedScopedProfile')
    name   = json.loads(raw).get('displayName','') if raw else ''
    token  = get('cursorAuth/accessToken')
    conn.close()

    usage = {}
    plan_info = {}
    if token:
        headers = {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'Authorization': 'Bearer ' + token,
        }
        for method, target in [
            ('GetCurrentPeriodUsage', usage),
            ('GetPlanInfo', plan_info),
        ]:
            try:
                req = urllib.request.Request(
                    f'https://api2.cursor.sh/aiserver.v1.DashboardService/{method}',
                    data=b'{}',
                    headers=headers,
                    method='POST',
                )
                with urllib.request.urlopen(req, timeout=4) as resp:
                    target.update(json.loads(resp.read().decode('utf-8')))
            except Exception:
                pass

    plan_usage = usage.get('planUsage') or {}
    plan_block = plan_info.get('planInfo') or {}
    total = plan_usage.get('totalSpend')
    limit = plan_usage.get('limit') or plan_block.get('includedAmountCents')
    auto_pct = plan_usage.get('autoPercentUsed')
    api_pct = plan_usage.get('apiPercentUsed')
    total_pct = plan_usage.get('totalPercentUsed')
    auto_spend = plan_usage.get('autoSpend')
    api_spend = plan_usage.get('apiSpend')
    cycle_end = usage.get('billingCycleEnd') or plan_block.get('billingCycleEnd')

    if usage:
        cursor_usage = "|".join([
            bar(auto_pct), fmt_pct(auto_pct), fmt_money(auto_spend) if auto_spend is not None else "",
            bar(api_pct), fmt_pct(api_pct), fmt_money(api_spend) if api_spend is not None else "",
            bar(total_pct), fmt_pct(total_pct), fmt_money(total), fmt_money(limit), fmt_date(cycle_end),
        ])
    else:
        cursor_usage = "unavailable||||||||||"

    print(f"{plan}|{status}|{name}|{cursor_usage}")
except Exception:
    print("unknown|unknown||unavailable||||||||||")
PYEOF
) &

(
python3 << 'PYEOF' > "$CODEX_TMP"
import glob, json, sqlite3, os, subprocess, time
from datetime import datetime

def bar(percent, w=22):
    p = max(0, min(float(percent or 0), 100)) / 100
    f = round(p * w)
    return "█" * f + "░" * (w - f)

def fmt_reset(ts, weekly=False):
    try:
        dt = datetime.fromtimestamp(float(ts))
        return dt.strftime("%-d %b") if weekly else dt.strftime("%H:%M")
    except Exception:
        return "n/a"

def short_label(dur_mins, default="5h"):
    try:
        if not dur_mins:
            return default
        m = int(dur_mins)
        if m % 60 == 0:
            return f"{m // 60}h"
        return f"{m}m"
    except Exception:
        return default

def emit(label, w, weekly=False):
    if w is None:
        print(f"{label}|{bar(0)}|n/a|n/a")
        return
    now = datetime.now()
    reset_ts = w.get("resetsAt", w.get("reset_at"))
    used_raw = w.get("usedPercent", w.get("used_percent", 0))
    try:
        used = max(0, min(100, float(used_raw or 0)))
    except Exception:
        used = 0.0
    reset_dt = None
    if reset_ts is not None:
        try:
            reset_dt = datetime.fromtimestamp(float(reset_ts))
        except Exception:
            reset_dt = None
    stale = bool(reset_dt and reset_dt <= now and not weekly)
    if stale:
        reset_label = f"passed {reset_dt.strftime('%H:%M')} · run codex to refresh"
        print(f"{label}|{bar(0)}|stale|{reset_label}")
    else:
        print(f"{label}|{bar(used)}|{used:.0f}|{fmt_reset(reset_ts, weekly)}")

def fetch_via_app_server(timeout=8):
    try:
        p = subprocess.Popen(
            ["codex", "app-server", "--stdio"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (FileNotFoundError, OSError):
        return None
    req = (
        '{"jsonrpc":"2.0","id":1,"method":"initialize",'
        '"params":{"clientInfo":{"name":"nn-usage","version":"1.0.7"}}}\n'
        '{"jsonrpc":"2.0","id":2,"method":"account/rateLimits/read","params":{}}\n'
    )
    rl = None
    try:
        p.stdin.write(req)
        p.stdin.flush()
        deadline = time.time() + timeout
        while time.time() < deadline:
            line = p.stdout.readline()
            if not line:
                break
            line = line.strip()
            if not line.startswith("{"):
                continue
            try:
                msg = json.loads(line)
            except Exception:
                continue
            if msg.get("id") == 2:
                res = msg.get("result") or {}
                rl = res.get("rateLimits")
                break
    except Exception:
        rl = None
    finally:
        try:
            p.kill()
        except Exception:
            pass
        try:
            p.wait(timeout=1)
        except Exception:
            pass
    return rl

def fetch_from_sqlite():
    db = os.path.expanduser('~/.codex/logs_2.sqlite')
    if not os.path.exists(db):
        return None
    try:
        conn = sqlite3.connect(db)
        cur = conn.cursor()
        cur.execute(
            "SELECT feedback_log_body FROM logs "
            "WHERE feedback_log_body LIKE '%\"type\":\"codex.rate_limits\"%' "
            "ORDER BY ts DESC LIMIT 1"
        )
        row = cur.fetchone()
        conn.close()
    except Exception:
        return None
    if not row:
        return None
    body = row[0]
    start = body.find('{')
    if start < 0:
        return None
    try:
        data = json.loads(body[start:])
    except Exception:
        return None
    return data.get('rate_limits')

def normalize(w):
    if not w:
        return None
    dur = w.get("windowDurationMins", w.get("window_duration_mins"))
    return {
        "usedPercent": w.get("usedPercent", w.get("used_percent")),
        "resetsAt": w.get("resetsAt", w.get("reset_at")),
        "windowDurationMins": dur,
    }

def pick_windows(rl):
    if not rl:
        return None, None
    short = None
    weekly = None
    for key in ("primary", "secondary"):
        w = normalize(rl.get(key))
        if w is None:
            continue
        d = w.get("windowDurationMins")
        if d is not None and d > 360:
            if weekly is None:
                weekly = w
        else:
            if short is None:
                short = w
    return short, weekly

def is_current(w):
    if not w:
        return False
    reset_ts = w.get("resetsAt", w.get("reset_at"))
    try:
        return float(reset_ts) > time.time()
    except Exception:
        return False

def compact_tokens(value):
    try:
        value = int(value)
    except Exception:
        return "n/a"
    if value >= 1_000_000:
        return f"{value / 1_000_000:.1f}m"
    if value >= 1_000:
        return f"{value / 1_000:.0f}k"
    return str(value)

def parse_iso_ts(text):
    if not text:
        return None
    try:
        s = text.rstrip("Z")
        if text.endswith("Z"):
            s += "+00:00"
        return datetime.fromisoformat(s)
    except Exception:
        return None

def fetch_session_usage():
    pattern = os.path.expanduser("~/.codex/sessions/**/*.jsonl")
    paths = sorted(glob.glob(pattern, recursive=True), reverse=True)
    for path in paths[:20]:
        latest = None
        session_start = None
        try:
            with open(path, errors="ignore") as fh:
                for line in fh:
                    if session_start is None:
                        try:
                            first = json.loads(line)
                            payload = first.get("payload") or {}
                            session_start = parse_iso_ts(
                                payload.get("timestamp") or first.get("timestamp")
                            )
                        except Exception:
                            pass
                    if '"type":"token_count"' not in line:
                        continue
                    try:
                        event = json.loads(line)
                    except Exception:
                        continue
                    payload = event.get("payload") or {}
                    info = payload.get("info") or {}
                    usage = info.get("last_token_usage") or {}
                    used = usage.get("total_tokens")
                    context = info.get("model_context_window")
                    if used is not None and context:
                        latest = (float(used), float(context))
        except Exception:
            continue
        if latest:
            used, context = latest
            pct = max(0, min(100, used / context * 100))
            reset_label = ""
            if session_start is not None:
                try:
                    from datetime import timedelta, timezone
                    reset_dt = session_start + timedelta(hours=5)
                    if reset_dt.tzinfo is None:
                        reset_dt = reset_dt.replace(tzinfo=timezone.utc)
                    now = datetime.now(reset_dt.tzinfo)
                    if reset_dt > now:
                        reset_label = f"reset {reset_dt.astimezone().strftime('%H:%M')}"
                except Exception:
                    reset_label = ""
            token_detail = f"{compact_tokens(used)} used"
            detail = f"{reset_label} · {token_detail}" if reset_label else token_detail
            return pct, detail
    return None

live_rl = fetch_via_app_server()
cached_rl = fetch_from_sqlite()

short, weekly = pick_windows(live_rl)
cached_short, cached_weekly = pick_windows(cached_rl)
if short is None and is_current(cached_short):
    short = cached_short
if weekly is None and is_current(cached_weekly):
    weekly = cached_weekly

# Keep the dashboard rows stable even when Codex temporarily omits one window:
# the first row is always the 5h allowance and the second is always weekly.
session_usage = fetch_session_usage() if short is None else None
if short is not None:
    emit("5h", short, weekly=False)
elif session_usage is not None:
    session_pct, session_detail = session_usage
    print(f"5h|{bar(session_pct)}|{session_pct:.0f}|{session_detail}|session")
else:
    emit("5h", None, weekly=False)
emit("Weekly", weekly, weekly=True)
PYEOF
) &

wait
