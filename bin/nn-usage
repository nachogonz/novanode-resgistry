def strip_ansi(s):
    import re
    return re.sub(r"\033\[[0-9;]*m", "", s)

def find_logo_path():
    import glob
    candidates = [
        os.path.expanduser(
            "~/Documents/† NovaNode/∆ NovaApp/clients/nova-app/public/logo.svg"
        ),
        os.path.expanduser("~/.cache/ai-usage/novanode-logo.png"),
    ]
    candidates.extend(
        glob.glob(
            os.path.expanduser(
                "~/Documents/*/NovaNode/*/clients/nova-app/public/logo.svg"
            )
        )
    )
    for path in candidates:
        if os.path.isfile(path):
            return path
    return None

def load_full_logo(path):
    try:
        from PIL import Image
    except ImportError:
        return None

    cache_dir = os.path.expanduser("~/.cache/ai-usage")
    cache_path = os.path.join(cache_dir, "novanode-full.png")

    def crop_content(image):
        px = image.load()
        xs, ys = [], []
        for y in range(image.height):
            for x in range(image.width):
                if px[x, y][3] >= 20:
                    xs.append(x)
                    ys.append(y)
        if not xs:
            return image
        return image.crop((min(xs), min(ys), max(xs) + 1, max(ys) + 1))

    try:
        src_mtime = os.path.getmtime(path) if os.path.isfile(path) else 0
        if os.path.isfile(cache_path) and os.path.getmtime(cache_path) >= src_mtime:
            return Image.open(cache_path).convert("RGBA")

        if path.lower().endswith(".svg"):
            import shutil
            import subprocess
            import tempfile

            rendered = None
            rsvg = shutil.which("rsvg-convert")
            if rsvg:
                tmp_png = os.path.join(cache_dir, ".logo-render.png")
                os.makedirs(cache_dir, exist_ok=True)
                result = subprocess.run(
                    [rsvg, "-w", str(LOGO_RENDER_WIDTH), "-o", tmp_png, path],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                if result.returncode == 0 and os.path.isfile(tmp_png):
                    rendered = Image.open(tmp_png).convert("RGBA")

            if rendered is None:
                try:
                    import cairosvg
                    from io import BytesIO

                    png = cairosvg.svg2png(
                        url=path,
                        output_width=LOGO_RENDER_WIDTH,
                        output_height=int(LOGO_RENDER_WIDTH * 100.862 / 372.882),
                    )
                    rendered = Image.open(BytesIO(png)).convert("RGBA")
                except Exception:
                    rendered = None

            if rendered is None:
                tmp = tempfile.mkdtemp(prefix="ai-usage-logo-")
                subprocess.run(
                    ["qlmanage", "-t", "-s", "1200", "-o", tmp, path],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    check=False,
                )
                png_path = os.path.join(tmp, os.path.basename(path) + ".png")
                if not os.path.isfile(png_path):
                    return None
                rendered = crop_content(Image.open(png_path).convert("RGBA"))

            img = rendered
        else:
            img = Image.open(path).convert("RGBA")

        os.makedirs(cache_dir, exist_ok=True)
        img.save(cache_path, format="PNG")
        return img
    except Exception:
        try:
            if os.path.isfile(cache_path):
                return Image.open(cache_path).convert("RGBA")
        except Exception:
            pass
    return None

def split_logo_parts(full):
    mark_w = min(full.width, max(1, int(full.width * MARK_CROP_RATIO) + 2))
    word_x = min(full.width - 1, int(full.width * WORD_CROP_START))
    mark = full.crop((0, 0, mark_w, full.height))
    word = full.crop((word_x, 0, full.width, full.height))

    def crop_content(image):
        px = image.load()
        xs, ys = [], []
        for y in range(image.height):
            for x in range(image.width):
                if px[x, y][3] >= 20:
                    xs.append(x)
                    ys.append(y)
        if not xs:
            return image
        return image.crop((min(xs), min(ys), max(xs) + 1, max(ys) + 1))

    return crop_content(mark), crop_content(word)

def image_to_halfblocks(image, width, height):
    from PIL import Image

    img = image.copy()
    img.thumbnail((width, height * 2), Image.Resampling.LANCZOS)
    w, h = img.size
    if h % 2:
        padded = Image.new("RGBA", (w, h + 1), (0, 0, 0, 0))
        padded.paste(img, (0, 0))
        img = padded
        h += 1

    px = img.load()
    lines = []
    for y in range(0, h, 2):
        parts = []
        for x in range(w):
            top = px[x, y]
            bot = px[x, y + 1]
            if top[3] < 20 and bot[3] < 20:
                parts.append(" ")
                continue
            if bot[3] < 20:
                parts.append(
                    f"\033[38;2;{top[0]};{top[1]};{top[2]}m▀{RESET}"
                )
            elif top[3] < 20:
                parts.append(
                    f"\033[48;2;{bot[0]};{bot[1]};{bot[2]}m▀{RESET}"
                )
            else:
                parts.append(
                    f"\033[38;2;{top[0]};{top[1]};{top[2]}m"
                    f"\033[48;2;{bot[0]};{bot[1]};{bot[2]}m▀{RESET}"
                )
        lines.append("".join(parts))

    return [line.rstrip() for line in lines if strip_ansi(line).strip()]

def boost_white(r, g, b):
    if r >= 140 and g >= 140 and b >= 140:
        return 255, 255, 255
    return r, g, b

def text_shaded_white(r, g, b):
    """Bright white with subtle 3D depth from the SVG letterforms."""
    lum = (r + g + b) / 3
    if lum < 120:
        return None
    hi = int(228 + (lum / 255) * 27)
    return (
        int(min(255, hi + (r - lum) // 6)),
        int(min(255, hi + (g - lum) // 6)),
        int(min(255, hi + (b - lum) // 6)),
    )

def isolate_text_pixels(image):
    """Keep only light text strokes; drop background and non-text color."""
    from PIL import Image

    img = image.copy()
    px = img.load()
    for y in range(img.height):
        for x in range(img.width):
            r, g, b, a = px[x, y]
            if a < 20:
                px[x, y] = (0, 0, 0, 0)
                continue
            if r >= 180 and g >= 180 and b >= 180:
                continue
            px[x, y] = (0, 0, 0, 0)
    return img

def image_to_braille(image, char_w, char_h, whiten=True):
    from PIL import Image

    braille_base = 0x2800
    dot_map = [
        (0, 0, 0),
        (0, 1, 1),
        (0, 2, 2),
        (0, 3, 6),
        (1, 0, 3),
        (1, 1, 4),
        (1, 2, 5),
        (1, 3, 7),
    ]

    img = image.copy()
    if whiten:
        img = isolate_text_pixels(img)
    img.thumbnail((char_w * 2, char_h * 4), Image.Resampling.LANCZOS)
    w, h = img.size
    pad_h = (4 - h % 4) % 4
    if pad_h:
        padded = Image.new("RGBA", (w, h + pad_h), (0, 0, 0, 0))
        padded.paste(img, (0, 0))
        img = padded
        h += pad_h

    px = img.load()
    lines = []
    for y in range(0, h, 4):
        row = []
        for x in range(0, w, 2):
            bits = 0
            colors = []
            for dx, dy, bit in dot_map:
                xx, yy = x + dx, y + dy
                if xx < w and yy < h:
                    pixel = px[xx, yy]
                    if pixel[3] >= 20:
                        if whiten:
                            shaded = text_shaded_white(*pixel[:3])
                            if shaded is None:
                                continue
                            bits |= 1 << bit
                            colors.append(shaded)
                        else:
                            bits |= 1 << bit
                            colors.append(pixel[:3])
            if bits:
                r = int(sum(c[0] for c in colors) // len(colors))
                g = int(sum(c[1] for c in colors) // len(colors))
                b = int(sum(c[2] for c in colors) // len(colors))
                row.append(f"\033[38;2;{r};{g};{b}m{chr(braille_base + bits)}{RESET}")
            else:
                row.append(" ")
        if strip_ansi("".join(row)).strip():
            lines.append("".join(row))

    return lines

def merge_logo_rows(left_lines, right_lines, gap=2, align="bottom"):
    height = len(left_lines)

    def pad(lines):
        if align == "bottom":
            return [""] * max(0, height - len(lines)) + lines
        top = (height - len(lines)) // 2
        bottom = height - len(lines) - top
        return [""] * top + lines + [""] * bottom

    left = left_lines
    right = pad(right_lines)
    spacer = " " * gap
    merged = []
    for left_line, right_line in zip(left, right):
        if strip_ansi(right_line).strip():
            merged.append(f"{left_line}{spacer}{right_line}".rstrip())
        else:
            merged.append(left_line)
    return merged

def wordmark_size(panel_w, mark_w=11, gap=2):
    budget = max(0, panel_w - mark_w - gap)
    if budget < 18:
        return 0, 0
    if budget < 26:
        return min(budget, 22), 3
    if budget < 34:
        return min(budget, 28), 4
    return min(budget, 32), 4

def render_mark_lines(path, width=11, height=6):
    try:
        from PIL import Image
    except ImportError:
        return []

    full = load_full_logo(path)
    if full is None:
        return []

    mark, _word = split_logo_parts(full)
    return image_to_halfblocks(mark, width, height)

def render_wordmark_lines(path, char_w, char_h):
    try:
        from PIL import Image
    except ImportError:
        return []

    full = load_full_logo(path)
    if full is None:
        return []

    _mark, word = split_logo_parts(full)
    return image_to_braille(word, char_w, char_h, whiten=True)

def compose_logo(path, panel_w):
    mark_w, mark_h, gap = 11, 6, 2
    mark = render_mark_lines(path, mark_w, mark_h)
    if not mark:
        return []

    mark_width = max(len(strip_ansi(line)) for line in mark)
    char_w, char_h = wordmark_size(panel_w, mark_width, gap)
    if char_w > 0 and char_h > 0:
        word = render_wordmark_lines(path, char_w, char_h)
        if word:
            merged = merge_logo_rows(mark, word, gap=gap, align="bottom")
            return [clip_line(line, panel_w) for line in merged]

    word_line = f"{BOLD}{WHITE}NovaNode{RESET}"
    out = list(mark)
    out[-1] = clip_line(f"{out[-1]}  {word_line}", panel_w)
    return [clip_line(line, panel_w) for line in out]

def clip_line(text, max_w):
    if len(strip_ansi(text)) <= max_w:
        return text
    out = []
    visible = 0
    i = 0
    while i < len(text):
        if text[i] == "\033":
            end = text.find("m", i)
            if end == -1:
                break
            out.append(text[i : end + 1])
            i = end + 1
            continue
        if visible >= max_w:
            break
        out.append(text[i])
        visible += 1
        i += 1
    out.append(RESET)
    return "".join(out)

def wrap_line(text, max_w):
    if not text:
        return [""]
    plain = strip_ansi(text)
    if len(plain) <= max_w:
        return [text]
    chunks = textwrap.wrap(plain, width=max_w)
    if plain.startswith("Claude ") or plain.startswith("/"):
        return [f"{DIM}{chunk}{RESET}" for chunk in chunks]
    if "Tips" in plain or "What's" in plain:
        return [f"{ORANGE}{chunk}{RESET}" for chunk in chunks]
    return [f"{GREEN}{chunk}{RESET}" for chunk in chunks]

def expand_panel(lines, max_w):
    out = []
    for line in lines:
        out.extend(wrap_line(line, max_w))
    return out

def pad_line(text, w):
    visible = len(strip_ansi(text))
    return text + " " * max(0, w - visible)

logo_path = find_logo_path()
logo = []
if logo_path:
    full_logo = load_full_logo(logo_path)
    if full_logo is not None:
        _mark, word = split_logo_parts(full_logo)
        logo = image_to_braille(word, min(38, width - 10), 4, whiten=True)
if not logo:
    logo = [f"{BOLD}{WHITE}NovaNode{RESET}"]

def centered(text):
    visible = len(strip_ansi(text))
    return " " * max(0, (width - visible) // 2) + text

print()
for line in logo:
    print(centered(line))
print(centered(f"{DIM}AI usage · Claude · Codex · Cursor{RESET}"))
print()
print(centered(f"{ORANGE}NovaNode{RESET}{DIM}  usage{RESET}"))
print(centered(f"{DIM}{'─' * min(84, width - 8)}{RESET}"))
print()
PYEOF

