echo "$MD" | LAYOUT="${LAYOUT}" python3 -c '
import os, sys, re

TARGET = 2
WIDTH = int(os.environ.get("LAYOUT", "96")) - 2
GREEN = "\033[38;5;82m"
ORANGE = "\033[38;5;208m"
DIM = "\033[38;5;245m"
BOLD = "\033[1m"
RESET = "\033[0m"

for line in sys.stdin:
    raw = line.rstrip("\n").strip()
    raw = raw.replace("**", "").replace("## ", "").strip("*")
    raw = raw.strip("|").strip()
    if not raw.replace("|", "").strip():
        print()
        continue
    if not raw:
        print()
        continue
    if raw == "TOTAL TOKENS":
        raw = f"{BOLD}{ORANGE}{raw}{RESET}"
    elif raw.startswith("Claude Code") or "| Codex CLI" in raw:
        raw = f"{BOLD}{GREEN}{raw}{RESET}"
    elif set(raw.replace("|", "").replace(" ", "")) <= {"-"}:
        divider = "─" * min(84, WIDTH)
        raw = f"{DIM}{divider}{RESET}"
    elif raw.startswith("Combined load") or raw == "claude · codex · cursor":
        raw = f"{DIM}{raw}{RESET}"
    else:
        raw = f"{GREEN}{raw}{RESET}"
    if "▮" in raw or "▯" in raw:
        raw = f"{BOLD}{raw}{RESET}"
    if "▯" in raw:
        raw = raw.replace("▯", f"{DIM}▯{GREEN}")
    vis = re.sub(r"\033\[[0-9;]*m", "", raw)
    if not vis.strip():
        print(raw)
        continue
    aligned = " " * TARGET + raw
    vis_aligned = re.sub(r"\033\[[0-9;]*m", "", aligned)
    if len(vis_aligned) < WIDTH:
        aligned = aligned + " " * (WIDTH - len(vis_aligned))
    print(aligned)
'

