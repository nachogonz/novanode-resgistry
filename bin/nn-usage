def codex_row1(label, pct, reset):
    # pct already carries % suffix or a keyword; reset already has "resets " prefix or "".
    if pct == "—" or label == "—":
        return cell("")
    if pct == "n/a":
        return cell(f"{label} · unavailable", "not provided by Codex API")
    return cell(f"{label} · {pct} used", reset)

def codex_row2(label, pct, reset):
    # pct is raw ("10", "n/a", "stale", "—"); reset is raw ("21 Jul", "n/a", ...).
    if pct == "—" or label == "—":
        return cell("")
    if pct == "stale":
        return cell(f"{label} · stale used", reset)
    if pct == "n/a":
        return cell(f"{label} · n/a used", "resets n/a")
    return cell(f"{label} · {pct}% used", f"resets {reset}")

def codex_bar(bar_str, pct):
    if pct == "—":
        return " " * w
    return f"{bar_str}{' ' * max(1, w - len(bar_str))}"

def number(value):
    try:
        return max(0.0, min(100.0, float(str(value).replace("%", "").strip())))
    except Exception:
        return None

def battery(label, value, footer):
    used = number(value)
    if used is None:
        meter = "▯▯" * 6
        status = "n/a"
    else:
        left = max(0, 100 - used)
        if left <= 0:
            filled = 0
        elif left >= 100:
            filled = 6
        else:
            filled = max(1, min(5, int(round(left / 100 * 6))))
        meter = "▮▮" * filled + "▯▯" * (6 - filled)
        status = f"{left:g}%"
    title = f"{label}"
    gauge = f"  {meter}  {status}"
    detail = f"  {footer}" if footer else ""
    return (
        title[:w].ljust(w),
        gauge[:w].ljust(w),
        detail[:w].ljust(w),
    )

c1, c1_gauge, c1_detail = battery("5h", c5_pct, f"reset {c5_reset}")
c2, c2_gauge, c2_detail = battery("Weekly", c7_pct, f"reset {c7_reset}")
x1, x1_gauge, x1_detail = battery(cx5_label, cx5_pct, cx5_reset)
x2, x2_gauge, x2_detail = battery(cx7_label, cx7_pct, f"reset {cx7_reset}")
r1, r1_gauge, r1_detail = battery("Auto", auto_pct, cycle_end)
r2, r2_gauge, r2_detail = battery("Premium", prem_pct, cycle_end)

rows = [
    f"| {cell(f'**Claude Code** v{cver}')} | {cell(f'**Codex CLI** v{cxver}')} | {cell(f'**Cursor** v{cursor_ver}')} |",
    f"| {rule()} | {rule()} | {rule()} |",
    f"| {cell('Plan Usage')} | {cell('Plan Usage')} | {cell('Plan Usage')} |",
    f"| {c1} | {x1} | {r1} |",
    f"| {c1_gauge} | {x1_gauge} | {r1_gauge} |",
    f"| {c1_detail} | {x1_detail} | {r1_detail} |",
    f"| {c2} | {x2} | {r2} |",
    f"| {c2_gauge} | {x2_gauge} | {r2_gauge} |",
    f"| {c2_detail} | {x2_detail} | {r2_detail} |",
]
print("\n".join(rows))
PYEOF
)

