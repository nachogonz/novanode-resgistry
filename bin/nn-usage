def plain_len(s):
    return len(re.sub(r"\*+", "", s))

def cell(label, tail=""):
    if tail:
        gap = max(2, w - plain_len(label) - len(tail))
        return f"{label}{' ' * gap}{tail}"
    return f"{label}{' ' * max(1, w - plain_len(label))}"

