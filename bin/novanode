screen = [""] * height

def center_line(text, target_width=width):
    visible = len(strip_ansi(text))
    return " " * max(0, (target_width - visible) // 2) + text

def put(row, text):
    if 0 <= row < height:
        screen[row] = fit(text, width)

def provider_rows():
    chunks = [compact_provider(p) for p in providers_sorted] if providers else []
    if not chunks:
        return [f"{DIM}usage unavailable{RESET}"]
    limit = max(20, card_w - 4)
    rows = []
    current = ""
    for chunk in chunks:
        candidate = chunk if not current else f"{current}   {chunk}"
        if current and len(strip_ansi(candidate)) > limit:
            rows.append(current)
            current = chunk
        else:
            current = candidate
    if current:
        rows.append(current)
    return rows

provider_strip_rows = provider_rows()
provider_h = len(provider_strip_rows)

def input_card(start_row):
    for idx, row_text in enumerate(input_rows_visible):
        prompt = f"{BOLD}{GREEN}›{RESET} " if idx == 0 and first_visible_input == 0 else "  "
        if not row_text and not input_buffer and idx == 0:
            display_text = f"{DIM}Ask NovaNode anything…{RESET}"
        else:
            display_text = row_text
        content = f"{prompt}{display_text}"
        content = fill(content, card_w - 2)
        put(
            start_row + idx,
            " " * card_left + f"{ORANGE}▎{RESET}{GRAY_BG}{content}{RESET}",
        )
    for index, provider_strip in enumerate(provider_strip_rows):
        put(start_row + input_h + index, " " * (card_left + 2) + provider_strip)

if not has_chat:
    hero = cached_hero_lines(min(38, max(20, width - 16)), 4)
    if not hero:
        hero = [f"{BOLD}{WHITE}NovaNode{RESET}"]

    hero_start = max(2, height // 2 - 11)
    for idx, line in enumerate(hero):
        put(hero_start + idx, center_line(line))

    subtitle = f"{DIM}AI terminal hub · Claude · Codex · Cursor{RESET}"
    put(hero_start + len(hero) + 1, center_line(subtitle))

    input_start_row = hero_start + len(hero) + 5
    input_card(input_start_row)
    tip = f"{ORANGE}● Tip{RESET}{DIM}  /claude  ·  /codex  ·  /cursor{RESET}"
    put(input_start_row + input_h + provider_h + 3, center_line(tip))
else:
    title_left = f" {BOLD}{ORANGE}NovaNode{RESET}{DIM}  chat{RESET}"
    if selected:
        header_window = selected.get("p1") or "5h"
        header_battery, header_usage = token_battery(selected.get("used1", "n/a"))
    else:
        header_window = "5h"
        header_battery, header_usage = token_battery("n/a")
        header_usage = "n/a"
    header_remaining = f"{header_usage} left" if header_usage != "n/a" else "n/a"
    title_right = (
        f"{GREEN}{active}{RESET}{DIM} · {active_model}"
        f"  ·  {header_window} {header_battery} {header_remaining}{RESET} "
    )
    put(0, status_row(title_left, title_right, width))
    put(1, f"{DIM}{'─' * width}{RESET}")

    input_start_row = height - input_h - provider_h
    status_row_index = input_start_row - 1
    chat_start_row = 2
    chat_h = max(1, status_row_index - chat_start_row)
    visible_chat = chat_lines[-chat_h:]
    first_chat_row = chat_start_row
    for idx, line in enumerate(visible_chat):
        put(first_chat_row + idx, "  " + fit(line, width - 4))
    put(status_row_index, status_row(status_left, status_right, width))
    input_card(input_start_row)

render_mode = sys.argv[11] if len(sys.argv) > 11 else "full"
sys.stdout.write("\033[?2026h\033[H" + ("\033[2J" if render_mode == "full" else ""))
for index, line in enumerate(screen):
    sys.stdout.write(line)
    if index < height - 1:
        sys.stdout.write("\n")

if state_line and state_line != "Press Ctrl+C again to quit NovaNode":
    sys.stdout.write("\033[?25l")
else:
    cursor_row_total = input_cursor // input_max_width
    cursor_col = input_cursor % input_max_width
    if input_cursor == len(input_buffer) and input_cursor > 0 and cursor_col == 0:
        cursor_row_total = max(0, cursor_row_total - 1)
        cursor_col = input_max_width
    if cursor_row_total < first_visible_input:
        cursor_row_visible = 0
        cursor_col = 0
    elif cursor_row_total >= first_visible_input + input_h:
        cursor_row_visible = input_h - 1
        cursor_col = input_max_width
    else:
        cursor_row_visible = cursor_row_total - first_visible_input
    cursor_screen_row = input_start_row + cursor_row_visible + 1
    cursor_screen_col = card_left + 4 + cursor_col
    sys.stdout.write(f"\033[{cursor_screen_row};{cursor_screen_col}H\033[?25h")

sys.stdout.write("\033[?2026l")
sys.stdout.flush()
PYEOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  -v|--version)
    echo "$VERSION"
    exit 0
    ;;
  claude|codex|cursor)
    exec_provider "$1"
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1" >&2
    echo "Run 'novanode --help' for usage." >&2
    exit 2
    ;;
esac

active_provider="claude"
default_model_claude="${NOVANODE_DEFAULT_MODEL_CLAUDE:-sonnet}"
default_model_codex="${NOVANODE_DEFAULT_MODEL_CODEX:-gpt-5.5}"
default_model_cursor="${NOVANODE_DEFAULT_MODEL_CURSOR:-default}"
model_claude="${NOVANODE_MODEL_CLAUDE:-}"
model_codex="${NOVANODE_MODEL_CODEX:-}"
model_cursor="${NOVANODE_MODEL_CURSOR:-}"
last_prompt=""
awaiting_approval=0
pending_prompt=""
awaiting_model=0
model_picker_provider=""
model_picker_options=()
CHAT_SCROLL_OFFSET=0
usage_data="$(load_usage)"
choose_default_provider

show_model_picker() {
  local provider="$1"
  local current="" opt id desc marker i
  local -a opts
  case "$provider" in
    claude)
      current="$model_claude"
      opts=(
        "default|Use claude CLI default"
        "sonnet|Sonnet — balanced everyday choice"
        "opus|Opus — most capable for complex work"
        "haiku|Haiku — fastest for quick answers"
      )
      ;;
    codex)
      current="$model_codex"
      opts=(
        "default|Use codex CLI default"
        "gpt-5.5|GPT-5.5"
        "gpt-5-codex|GPT-5 Codex"
        "gpt-5|GPT-5"
      )
      ;;
    cursor)
      current="$model_cursor"
      opts=(
        "default|Use Cursor Agent default"
      )
      ;;
  esac
  awaiting_model=1
  model_picker_provider="$provider"
  model_picker_options=("${opts[@]}")
  {
    printf "NovaNode-picker: Select model for %s\n" "$provider"
    i=1
    for opt in "${opts[@]}"; do
      id="${opt%%|*}"
      desc="${opt#*|}"
      if { [ -z "$current" ] && [ "$id" = "default" ]; } || [ "$id" = "$current" ]; then
        marker="✔ "
      else
        marker="  "
      fi
      printf "NovaNode-picker: %s%d. %s — %s\n" "$marker" "$i" "$id" "$desc"
      i=$((i + 1))
    done
    printf "NovaNode-picker: Type a number and press Enter · anything else to cancel.\n"
  } >> "$TRANSCRIPT_FILE"
}

models_arg() {
  printf "claude=%s|codex=%s|cursor=%s" \
    "${model_claude:-$default_model_claude}" \
    "${model_codex:-$default_model_codex}" \
    "${model_cursor:-$default_model_cursor}"
}

ORIGINAL_STTY=""

enter_live_screen() {
  if [ -t 0 ]; then
    ORIGINAL_STTY="$(stty -g 2>/dev/null || true)"
    # Deliver Ctrl+C to the editor as \x03 so it can implement the same
    # clear-then-exit interaction as Claude instead of receiving SIGINT.
    # `intr undef` is essential on macOS Bash 3: even if Bash temporarily
    # toggles ISIG internally, Ctrl+C remains an ordinary input byte.
    stty -echo -icanon min 1 time 0 -isig intr undef 2>/dev/null || true
  fi
  if [ -t 1 ]; then
    # Keep the dashboard inside one fixed alternate-screen viewport. Disabling
    # autowrap prevents a terminal-width row from spilling into scrollback.
    # Capture wheel/click events inside the alternate-screen environment. The
    # input state machine consumes the complete report and only wheel events
    # move chat history, so the host terminal never enters its own scrollback.
    printf "\033[?1049h\033[?7l\033[?1000l\033[?1002l\033[?1003h\033[?1006h\033[?1007l\033[?2004l\033[H\033[2J\033[3J\033[?25h"
  fi
}

leave_live_screen() {
  if [ -t 0 ] && [ -n "$ORIGINAL_STTY" ]; then
    stty "$ORIGINAL_STTY" 2>/dev/null || true
  fi
  if [ -t 1 ]; then
    printf "\033[?2026h\033[?25h\033[?1006l\033[?1003l\033[?1002l\033[?1000l\033[?1007l\033[?7h\033[?2004l\033[H\033[2J\033[?1049l\033[?2026l"
  else
    printf "\033[?25h\033[?1006l\033[?1003l\033[?1002l\033[?1000l\033[?1007l\033[?7h\033[?2004l"
  fi
}

TRANSCRIPT_FILE=$(mktemp "${TMPDIR:-/tmp}/novanode-chat.XXXXXX")
trap 'rm -f "$TRANSCRIPT_FILE" 2>/dev/null; leave_live_screen' EXIT
CTRL_C_SIGNAL=0
CTRL_C_BYTE_SEEN=0
trap 'if [ "${CTRL_C_BYTE_SEEN:-0}" -eq 1 ]; then CTRL_C_BYTE_SEEN=0; else CTRL_C_SIGNAL=1; fi' INT

snapshot_git() {
  command -v git >/dev/null 2>&1 || return 0
  git -C "$WORKSPACE_DIR" status --porcelain 2>/dev/null | LC_ALL=C sort
}

diff_snapshot() {
  local before="$1" after="$2"
  [ "$before" = "$after" ] && return 0
  diff <(printf "%s\n" "$before") <(printf "%s\n" "$after") 2>/dev/null \
    | awk '/^> /{ sub(/^> /, ""); print }'
}

kill_process_tree() {
  local pid="$1"
  local child
  for child in $(pgrep -P "$pid" 2>/dev/null); do
    kill_process_tree "$child"
  done
  kill -TERM "$pid" 2>/dev/null
}

run_with_activity() {
  local provider="$1"
  local prompt="$2"
  local transcript_file="$3"
  local approve="$4"
  local before_snap
  before_snap="$(snapshot_git)"

  ( run_prompt "$provider" "$prompt" "$transcript_file" "$approve" < /dev/null ) &
  local run_pid=$!

  (
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    local prev_snap="$before_snap"
    local curr_snap new
    while kill -0 "$run_pid" 2>/dev/null; do
      if [ $((i % 3)) -eq 0 ]; then
        curr_snap="$(snapshot_git)"
        if [ -n "$curr_snap" ] && [ "$curr_snap" != "$prev_snap" ]; then
          new="$(diff_snapshot "$prev_snap" "$curr_snap")"
          if [ -n "$new" ]; then
            while IFS= read -r line; do
              [ -n "$line" ] && printf "NovaNode-changes: %s\n" "$line" >> "$transcript_file"
            done <<< "$new"
          fi
          prev_snap="$curr_snap"
        fi
      fi
      local frame="${frames[i % ${#frames[@]}]}"
      render_screen "$provider" "$usage_data" "$transcript_file" "$frame $provider is working… (esc to cancel)" "$(models_arg)"
      i=$((i + 1))
      sleep 0.15
    done
  ) &
  local anim_pid=$!

  local cancelled=0
  local key esc_next esc_tail esc_wait="1"
  if (( ${BASH_VERSINFO[0]:-0} >= 4 )); then
    esc_wait="0.05"
  fi
  while kill -0 "$run_pid" 2>/dev/null; do
    if IFS= read -rsn1 -t 1 key 2>/dev/null; then
      if [ "$key" = $'\e' ]; then
        esc_next=""
        IFS= read -rsn1 -t "$esc_wait" esc_next 2>/dev/null || :
        if [ -z "$esc_next" ]; then
          cancelled=1
          printf "NovaNode: run cancelled (ESC). Provider process terminated.\n" >> "$transcript_file"
          kill_process_tree "$run_pid"
          break
        fi
        # Mouse reports and navigation keys also begin with ESC. Drain their
        # remaining CSI bytes instead of treating them as cancellation.
        if [ "$esc_next" = "[" ]; then
          esc_tail=""
          while IFS= read -rsn1 -t "$esc_wait" esc_tail 2>/dev/null; do
            case "$esc_tail" in M|m|~|A|B|C|D) break ;; esac
          done
        fi
      fi
    fi
  done

  kill "$anim_pid" 2>/dev/null
  wait "$anim_pid" 2>/dev/null
  wait "$run_pid" 2>/dev/null
  local status=$?

  local after_snap
  after_snap="$(snapshot_git)"
  local final_diff
  final_diff="$(diff_snapshot "$before_snap" "$after_snap")"
  if [ -n "$final_diff" ]; then
    local stat_line
    stat_line="$(git -C "$WORKSPACE_DIR" diff --shortstat 2>/dev/null)"
    [ -n "$stat_line" ] && printf "NovaNode-changes: %s\n" "$stat_line" >> "$transcript_file"
  fi
  [ "$cancelled" -eq 1 ] && return 130
  return "$status"
}

read_prompt() {
  if [ ! -t 0 ] || [ ! -t 1 ]; then
    IFS= read -r REPLY
    return $?
  fi
  local buffer="" cursor=0 ctrl_c_armed=0 pending_key="" input_notice=""
  local key e1 e2 tail paste_more start mouse_seq mouse_char mouse_button key_from_signal=0 skip_redraw=0
  local t_esc="1" has_frac=0
  if (( ${BASH_VERSINFO[0]:-0} >= 4 )); then
    has_frac=1
    t_esc="0.05"
  fi
  render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "$input_notice" "$(models_arg)" "$buffer" "$cursor"
  while true; do
    CTRL_C_BYTE_SEEN=0
    key_from_signal=0
    skip_redraw=0
    if [ -n "$pending_key" ]; then
      key="$pending_key"
      pending_key=""
    elif [ "$CTRL_C_SIGNAL" -eq 1 ]; then
      CTRL_C_SIGNAL=0
      key=$'\x03'
      key_from_signal=1
    else
      # Bash 3 can briefly restore ISIG around `read -n`. Reassert raw signal
      # handling directly before the read so Ctrl+C is always queued as a byte
      # and never waits for a later key to wake the editor.
      stty -isig -icanon -echo min 1 time 0 intr undef 2>/dev/null || true
      if IFS= read -rsn1 key; then
        :
      elif [ "$CTRL_C_SIGNAL" -eq 1 ]; then
        CTRL_C_SIGNAL=0
        key=$'\x03'
        key_from_signal=1
      else
        REPLY=""
        return 1
      fi
    fi
    if [ "$CTRL_C_SIGNAL" -eq 1 ]; then
      # A SIGINT may arrive just after read returned on macOS Bash 3.
      CTRL_C_SIGNAL=0
      if [[ "$key" != $'\x03' ]]; then
        key=$'\x03'
        key_from_signal=1
      fi
    fi
    if [[ -z "$key" ]]; then
      local peek=""
      if [ "$has_frac" -eq 1 ]; then
        IFS= read -rsn1 -t 0.005 peek 2>/dev/null || :
      fi
      if [ -z "$peek" ]; then
        REPLY="$buffer"
        return 0
      fi
      buffer="${buffer:0:$cursor} ${buffer:$cursor}"
      cursor=$((cursor + 1))
      local _pi=0 _pn=${#peek} _pch=""
      while [ "$_pi" -lt "$_pn" ]; do
        _pch="${peek:$_pi:1}"
        _pi=$((_pi + 1))
        case "$_pch" in
          $'\n'|$'\r')
            buffer="${buffer:0:$cursor} ${buffer:$cursor}"
            cursor=$((cursor + 1))
            continue
            ;;
          $'\x03')
            CTRL_C_SIGNAL=0
            CTRL_C_BYTE_SEEN=1
            if [ "$ctrl_c_armed" -eq 1 ]; then
              REPLY=""
              return 130
            fi
            buffer=""
            cursor=0
            ctrl_c_armed=1
            input_notice="Press Ctrl+C again to quit NovaNode"
            break
            ;;
          $'\x1b'|$'\x04'|$'\x7f'|$'\x08')
            break
            ;;
        esac
        buffer="${buffer:0:$cursor}${_pch}${buffer:$cursor}"
        cursor=$((cursor + 1))
      done
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "$input_notice" "$(models_arg)" "$buffer" "$cursor" update
      continue
    fi
    if [[ "$key" != $'\x03' && "$key" != $'\x1b' ]]; then
      ctrl_c_armed=0
      input_notice=""
    fi
    case "$key" in
      $'\x1b')
        e1=""; e2=""
        IFS= read -rsn1 -t "$t_esc" e1 2>/dev/null || :
        if [[ -z "$e1" ]]; then
          REPLY=""
          return 130
        fi
        IFS= read -rsn1 -t "$t_esc" e2 2>/dev/null || :
        case "$e1$e2" in
          '[<')
            mouse_seq=""
            mouse_char=""
            while [ "${#mouse_seq}" -lt 64 ]; do
              IFS= read -rsn1 -t "$t_esc" mouse_char 2>/dev/null || break
              case "$mouse_char" in
                M|m) break ;;
                *) mouse_seq="${mouse_seq}${mouse_char}" ;;
              esac
            done
            mouse_button="${mouse_seq%%;*}"
            case "$mouse_button" in
              *) skip_redraw=1 ;;
            esac
            ;;
          '[A'|'OA'|'[B'|'OB') skip_redraw=1 ;;
          '[C'|'OC') [ "$cursor" -lt "${#buffer}" ] && cursor=$((cursor + 1)) ;;
          '[D'|'OD') [ "$cursor" -gt 0 ] && cursor=$((cursor - 1)) ;;
          '[H'|'OH') cursor=0 ;;
          '[F'|'OF') cursor="${#buffer}" ;;
          '[1'|'[3'|'[4'|'[5'|'[6'|'[7'|'[8')
            tail=""
            IFS= read -rsn1 -t "$t_esc" tail 2>/dev/null || :
            case "$e1$e2" in
              '[3')
                if [ "$cursor" -lt "${#buffer}" ]; then
                  buffer="${buffer:0:$cursor}${buffer:$((cursor + 1))}"
                fi
                ;;
              '[1'|'[7') cursor=0 ;;
              '[4'|'[8') cursor="${#buffer}" ;;
              '[5'|'[6') skip_redraw=1 ;;
            esac
            ;;
          *) ;;
        esac
        ;;
      $'\x7f'|$'\x08')
        if [ "$cursor" -gt 0 ]; then
          buffer="${buffer:0:$((cursor - 1))}${buffer:$cursor}"
          cursor=$((cursor - 1))
        fi
        ;;
      $'\x03')
        CTRL_C_SIGNAL=0
        if [ "$key_from_signal" -eq 0 ]; then
          CTRL_C_BYTE_SEEN=1
        fi
        if [ "$ctrl_c_armed" -eq 1 ]; then
          REPLY=""
          return 130
        fi
        # Match the native provider CLIs: the first Ctrl+C clears the editor;
        # a second consecutive Ctrl+C exits NovaNode.
        buffer=""
        cursor=0
        ctrl_c_armed=1
        input_notice="Press Ctrl+C again to quit NovaNode"
        ;;
      $'\x04')
        if [ -z "$buffer" ]; then
          REPLY=""
          return 1
        fi
        ;;
      $'\x15')
        buffer="${buffer:$cursor}"
        cursor=0
        ;;
      $'\x01') cursor=0 ;;
      $'\x05') cursor="${#buffer}" ;;
      $'\x17')
        start=$cursor
        while [ "$start" -gt 0 ] && [[ "${buffer:$((start - 1)):1}" == " " ]]; do
          start=$((start - 1))
        done
        while [ "$start" -gt 0 ] && [[ "${buffer:$((start - 1)):1}" != " " ]]; do
          start=$((start - 1))
        done
        buffer="${buffer:0:$start}${buffer:$cursor}"
        cursor=$start
        ;;
      *)
        buffer="${buffer:0:$cursor}${key}${buffer:$cursor}"
        cursor=$((cursor + 1))
        if [ "$has_frac" -eq 1 ]; then
          while IFS= read -rsn1 -t 0.003 paste_more 2>/dev/null; do
            if [[ -z "$paste_more" ]]; then
              buffer="${buffer:0:$cursor} ${buffer:$cursor}"
              cursor=$((cursor + 1))
              continue
            fi
            case "$paste_more" in
              $'\x03')
                CTRL_C_SIGNAL=0
                CTRL_C_BYTE_SEEN=1
                if [ "$ctrl_c_armed" -eq 1 ]; then
                  REPLY=""
                  return 130
                fi
                buffer=""
                cursor=0
                ctrl_c_armed=1
                input_notice="Press Ctrl+C again to quit NovaNode"
                break
                ;;
              $'\x1b'|$'\x04'|$'\x7f'|$'\x08')
                pending_key="$paste_more"
                break
                ;;
            esac
            buffer="${buffer:0:$cursor}${paste_more}${buffer:$cursor}"
            cursor=$((cursor + 1))
          done
        else
          # macOS ships Bash 3, which only supports integer read timeouts.
          # A zero-timeout drain batches already queued printable input while
          # deferring control keys to the normal state machine.
          while IFS= read -rsn1 -t 0 paste_more 2>/dev/null; do
            if [[ -z "$paste_more" ]]; then
              buffer="${buffer:0:$cursor} ${buffer:$cursor}"
              cursor=$((cursor + 1))
              continue
            fi
            case "$paste_more" in
              $'\x03')
                CTRL_C_SIGNAL=0
                CTRL_C_BYTE_SEEN=1
                if [ "$ctrl_c_armed" -eq 1 ]; then
                  REPLY=""
                  return 130
                fi
                buffer=""
                cursor=0
                ctrl_c_armed=1
                input_notice="Press Ctrl+C again to quit NovaNode"
                break
                ;;
              $'\x1b'|$'\x04'|$'\x7f'|$'\x08')
                pending_key="$paste_more"
                break
                ;;
            esac
            buffer="${buffer:0:$cursor}${paste_more}${buffer:$cursor}"
            cursor=$((cursor + 1))
          done
        fi
        ;;
    esac
    [ "$skip_redraw" -eq 1 ] && continue
    render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "$input_notice" "$(models_arg)" "$buffer" "$cursor" update
  done
}

enter_live_screen
render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"

handle_prompt() {
  local prompt_text="$1"
  local approve="${2:-0}"
  last_prompt="$prompt_text"
  render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "⠋ $active_provider is starting…" "$(models_arg)"
  run_with_activity "$active_provider" "$prompt_text" "$TRANSCRIPT_FILE" "$approve"
  local run_status=$?
  usage_data="$(load_usage)"
  choose_default_provider
  if [ "$run_status" -ne 130 ] && [ "$approve" -eq 0 ] && needs_approval "$TRANSCRIPT_FILE"; then
    awaiting_approval=1
    pending_prompt="$prompt_text"
    printf "NovaNode: Approval needed.\n" >> "$TRANSCRIPT_FILE"
  fi
  render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
}

while true; do
  if [ "$awaiting_approval" -eq 1 ]; then
    # Single-key approval replaces the input line. No Enter needed.
    printf "\r\033[2K"
    printf "\033[38;5;208m▶\033[0m Approve? \033[1m\033[38;5;82my\033[0m yes  \033[1m\033[38;5;196mn\033[0m no "
    IFS= read -rsn1 approval_key || approval_key=""
    printf "\r\033[2K"
    case "$approval_key" in
      y|Y)
        awaiting_approval=0
        printf "You: [%s] (y) approve\n" "$active_provider" >> "$TRANSCRIPT_FILE"
        handle_prompt "$pending_prompt" 1
        pending_prompt=""
        ;;
      *)
        awaiting_approval=0
        pending_prompt=""
        printf "You: [%s] (n) skip\n" "$active_provider" >> "$TRANSCRIPT_FILE"
        render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
        ;;
    esac
    continue
  fi

  read_prompt || break
  input="$REPLY"
  CHAT_SCROLL_OFFSET=0

  if [ "$awaiting_model" -eq 1 ]; then
    awaiting_model=0
    picker_count="${#model_picker_options[@]}"
    if [[ "$input" =~ ^[0-9]+$ ]] && [ "$input" -ge 1 ] && [ "$input" -le "$picker_count" ]; then
      chosen="${model_picker_options[input-1]}"
      chosen_id="${chosen%%|*}"
      if [ "$chosen_id" = "default" ]; then
        new_model=""
      else
        new_model="$chosen_id"
      fi
      case "$model_picker_provider" in
        claude) model_claude="$new_model" ;;
        codex)  model_codex="$new_model" ;;
        cursor) model_cursor="$new_model" ;;
      esac
      printf "NovaNode: %s model set to %s.\n" "$model_picker_provider" "${new_model:-default}" >> "$TRANSCRIPT_FILE"
    else
      printf "NovaNode: model selection cancelled.\n" >> "$TRANSCRIPT_FILE"
    fi
    model_picker_provider=""
    model_picker_options=()
    render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
    continue
  fi

  case "$input" in
    "")
      # Empty Enter is a no-op. Move cursor back up so the next prompt
      # overwrites the empty line rather than stacking new '›' rows.
      printf "\033[F"
      continue
      ;;
    /q|/quit|exit)
      break
      ;;
    /h|/help)
      printf "NovaNode: opened help for commands.\n" >> "$TRANSCRIPT_FILE"
      usage
      ;;
    /providers)
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /usage)
      usage_data="$(load_usage)"
      choose_default_provider
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /model)
      show_model_picker "$active_provider"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /model\ *)
      model_args="${input#/model }"
      read -r -a model_tokens <<< "$model_args"
      case "${model_tokens[0]}" in
        claude|codex|cursor)
          target_provider="${model_tokens[0]}"
          new_model="${model_tokens[*]:1}"
          ;;
        *)
          target_provider="$active_provider"
          new_model="$model_args"
          ;;
      esac
      if [ -z "$new_model" ]; then
        show_model_picker "$target_provider"
      else
        case "$target_provider" in
          claude) model_claude="$new_model" ;;
          codex)  model_codex="$new_model" ;;
          cursor) model_cursor="$new_model" ;;
        esac
        printf "NovaNode: %s model set to %s.\n" "$target_provider" "$new_model" >> "$TRANSCRIPT_FILE"
      fi
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /open)
      printf "NovaNode: opening native %s interface.\n" "$active_provider" >> "$TRANSCRIPT_FILE"
      leave_live_screen
      exec_provider "$active_provider"
      # Re-enter only if exec failed and returned to this process.
      enter_live_screen
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /claude|/codex|/cursor)
      active_provider="${input#/}"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /use\ *)
      next="${input#/use }"
      case "$next" in
        claude|codex|cursor)
          active_provider="$next"
          render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
          ;;
        *)
          printf "NovaNode: invalid provider '%s'.\n" "$next" >> "$TRANSCRIPT_FILE"
          echo "Choose claude, codex, or cursor."
          ;;
      esac
      ;;
    /*/*|*.png*|*.PNG*|*.jpg*|*.JPG*|*.jpeg*|*.JPEG*|*.webp*|*.WEBP*|*.gif*|*.GIF*|*.bmp*|*.BMP*|*.tiff*|*.TIFF*|*.heic*|*.HEIC*|~/*)
      display_input="$(summarize_prompt_for_chat "$input")"
      printf "\r\033[2K"
      printf "You: [%s] %s\n" "$active_provider" "$display_input" >> "$TRANSCRIPT_FILE"
      handle_prompt "$input" 0
      ;;
    /*)
      printf "NovaNode: unknown command '%s'.\n" "$input" >> "$TRANSCRIPT_FILE"
      echo "Unknown command. Run /help."
      ;;
    *)
      display_input="$(summarize_prompt_for_chat "$input")"
      printf "\r\033[2K"
      printf "You: [%s] %s\n" "$active_provider" "$display_input" >> "$TRANSCRIPT_FILE"
      handle_prompt "$input" 0
      ;;
  esac
done
