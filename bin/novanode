def wrap_input(buf, cur):
    if not buf:
        return [""]
    rows = []
    i = 0
    while i < len(buf):
        rows.append(buf[i:i + input_max_width])
        i += input_max_width
    if cur == len(buf) and cur > 0 and cur % input_max_width == 0:
        rows.append("")
    return rows

all_input_rows = wrap_input(input_buffer, input_cursor)
