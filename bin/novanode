#!/usr/bin/env bash

VERSION="1.0.4"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NN_USAGE="${SCRIPT_DIR}/nn-usage"

ORANGE=$'\033[38;5;208m'
GREEN=$'\033[38;5;82m'
DIM=$'\033[38;5;245m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

usage() {
  cat << EOF
NovaNode

AI terminal hub for Claude, Codex and Cursor.

Usage:
  novanode
  novanode --help
  novanode --version
  novanode claude
  novanode codex
  novanode cursor

Inside NovaNode:
  /use claude|codex|cursor  Select provider
  /open                     Open selected provider CLI
  /usage                    Refresh usage summary
  /providers                Show providers
  /quit                     Exit
EOF
}

provider_cmd() {
  case "$1" in
    claude) echo "claude" ;;
    codex) echo "codex" ;;
    cursor) echo "cursor" ;;
  esac
}

provider_label() {
  case "$1" in
    claude) echo "Claude Code" ;;
    codex) echo "Codex CLI" ;;
    cursor) echo "Cursor" ;;
  esac
}

exec_provider() {
  local provider="$1"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi
  if [ "$provider" = "cursor" ]; then
    exec "$cmd" --chat
  fi
  exec "$cmd"
}

send_prompt() {
  local provider="$1"
  local prompt="$2"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi

  case "$provider" in
    claude|codex)
      "$cmd" "$prompt"
      ;;
    cursor)
      echo "NovaNode: Cursor CLI does not expose a stable terminal chat prompt."
      echo "Opening Cursor Chat instead."
      "$cmd" --chat
      ;;
  esac
}

append_prefixed() {
  local prefix="$1"
  local file="$2"
  if [ ! -s "$file" ]; then
    printf "%s: No response captured.\n" "$prefix"
    return 0
  fi

  while IFS= read -r line; do
    if [ -n "$line" ]; then
      printf "%s: %s\n" "$prefix" "$line"
    fi
  done < "$file"
}

run_prompt() {
  local provider="$1"
  local prompt="$2"
  local transcript_file="$3"
  local cmd output status

  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf "NovaNode: %s is not installed or not on PATH.\n" "$cmd" >> "$transcript_file"
    return 127
  fi

  output=$(mktemp "${TMPDIR:-/tmp}/novanode-response.XXXXXX")
  case "$provider" in
    claude)
      "$cmd" --print "$prompt" >"$output" 2>&1
      status=$?
      ;;
    codex)
      "$cmd" exec --color never --output-last-message "$output" "$prompt" >/dev/null 2>>"$output"
      status=$?
      ;;
    cursor)
      printf "NovaNode: Cursor CLI does not expose terminal chat responses. Use /open to launch Cursor Chat.\n" >> "$transcript_file"
      rm -f "$output"
      return 0
      ;;
  esac

  if [ "$status" -ne 0 ]; then
    printf "NovaNode: %s exited with status %s.\n" "$provider" "$status" >> "$transcript_file"
  fi
  append_prefixed "$(provider_label "$provider")" "$output" >> "$transcript_file"
  rm -f "$output"
  return "$status"
}

load_usage() {
  if [ ! -x "$NN_USAGE" ]; then
    echo ""
    return 0
  fi
  AI_USAGE_NO_REFRESH_PROMPT=1 "$NN_USAGE" --summary-tsv </dev/null 2>/dev/null || true
}

render_screen() {
  local active="$1"
  local data="$2"
  local transcript_file="$3"
  local state_line="${4:-}"
  python3 - "$active" "$data" "$transcript_file" "$state_line" "$VERSION" << 'PYEOF'
import re, shutil, sys, textwrap

active = sys.argv[1]
raw = sys.argv[2]
transcript_file = sys.argv[3]
state_line = sys.argv[4]
script_version = sys.argv[5]
size = shutil.get_terminal_size((106, 34))
width = max(80, size.columns)
height = max(24, size.lines)

ORANGE = "\033[38;5;208m"
GREEN = "\033[38;5;82m"
WHITE = "\033[38;2;249;249;249m"
GRAY_BG = "\033[48;5;237m"
DIM = "\033[38;5;245m"
BOLD = "\033[1m"
RESET = "\033[0m"

providers = []

def strip_ansi(text):
    return re.sub(r"\033\[[0-9;]*m", "", text)

def fit(text, limit):
    plain = strip_ansi(text)
    if len(plain) <= limit:
        return text + " " * (limit - len(plain))
    out = []
    visible = 0
    i = 0
    while i < len(text) and visible < limit - 1:
        if text[i] == "\033":
            end = text.find("m", i)
            if end == -1:
                break
            out.append(text[i:end + 1])
            i = end + 1
            continue
        out.append(text[i])
        visible += 1
        i += 1
    out.append("…")
    out.append(RESET)
    return "".join(out)

def fill(text, limit):
    plain = strip_ansi(text)
    return text + " " * max(0, limit - len(plain))

def fmt_pct(value):
    if value in ("", "n/a", "stale"):
        return value or "n/a"
    return f"{value}%"

for line in raw.splitlines():
    cols = line.split("\t")
    if len(cols) < 11:
        continue
    key, command, version, p1, used1, left1, reset1, p2, used2, left2, reset2 = cols[:11]
    providers.append({
        "key": key,
        "command": command,
        "name": {"claude": "Claude Code", "codex": "Codex CLI", "cursor": "Cursor"}.get(key, key),
        "version": f"v{version}" if version != "n/a" else "not detected",
        "p1": p1,
        "used1": used1,
        "left1": left1,
        "reset1": reset1,
        "p2": p2,
        "used2": used2,
        "left2": left2,
        "reset2": reset2,
    })

selected = next((p for p in providers if p["key"] == active), providers[0] if providers else None)

messages = []
try:
    with open(transcript_file) as fh:
        messages = [line.rstrip("\n") for line in fh if line.strip()]
except Exception:
    pass

def compact_provider(provider):
    if not provider:
        return f"{DIM}usage unavailable{RESET}"
    selected_mark = "●" if provider["key"] == active else "○"
    tone = GREEN if provider["key"] == active else DIM
    return (
        f"{tone}{selected_mark} {provider['key']} {provider['version']} "
        f"{provider['p1']}:{fmt_pct(provider['left1'])} "
        f"{provider['p2']}:{fmt_pct(provider['left2'])}{RESET}"
    )

def header_usage(provider):
    if not provider:
        return f"{DIM}usage unavailable{RESET}"
    return (
        f"{GREEN if provider['key'] == active else DIM}"
        f"{provider['key']} {provider['version']}{RESET}"
        f"{DIM} · {provider['p1']} {fmt_pct(provider['left1'])} left"
        f" · {provider['p2']} {fmt_pct(provider['left2'])} left{RESET}"
    )

def wrap_plain(text, limit):
    if not text:
        return [""]
    return textwrap.wrap(text, width=max(8, limit)) or [""]

def user_block(text, limit):
    out = []
    for line in wrap_plain(text, limit - 2):
        pad = max(0, limit - 2 - len(line))
        out.append(f"{GRAY_BG}{WHITE} {line}{' ' * pad} {RESET}")
    return out

def assistant_block(text, limit):
    return [f"{GREEN}{line}{RESET}" for line in wrap_plain(text, limit)]

def think_block(text, limit):
    return [f"{ORANGE}{line}{RESET}" for line in wrap_plain(text, limit)]

header_inner = width - 4
left_w = max(32, min(44, (header_inner - 3) // 2))
right_w = header_inner - left_w - 3
title = f" NovaNode · AI Terminal · v{script_version} "

def box_top_line():
    return f"{ORANGE}╭─{title}{'─' * max(0, header_inner - len(title))}╮{RESET}"

def box_bottom_line():
    return f"{ORANGE}╰{'─' * (header_inner + 2)}╯{RESET}"

def wrap_block(lines, width_limit):
    out = []
    for line in lines:
        out.extend(wrap_plain(line, width_limit))
    return out

left_lines = wrap_block(
    [
        f"{BOLD}{WHITE}NovaNode{RESET}",
        f"{GREEN}Chat stays here; providers run in-house.{RESET}",
        f"{DIM}{selected['key'] if selected else 'claude'} {selected['version'] if selected else 'n/a'} · {script_version}{RESET}",
    ],
    left_w,
)
right_lines = wrap_block(
    [
        f"{BOLD}{GREEN}Pick a provider. See usage before tokens.{RESET}",
        f"{DIM}/use claude · /use codex · /use cursor · /open{RESET}",
        f"{DIM}/usage · /quit{RESET}",
        f"{GREEN}Usage stays inline; chat keeps room.{RESET}",
    ],
    right_w,
)

header_rows = max(len(left_lines), len(right_lines))
header = [box_top_line()]
for index in range(header_rows):
    left_text = left_lines[index] if index < len(left_lines) else ""
    right_text = right_lines[index] if index < len(right_lines) else ""
    header.append(
        f"{ORANGE}│{RESET} {fill(left_text, left_w)} {ORANGE}│{RESET} {fill(right_text, right_w)} {ORANGE}│{RESET}"
    )
header.append(box_bottom_line())

chat_lines = []
for msg in messages:
    if msg.startswith("You:"):
        content = msg.split("] ", 1)[-1] if "] " in msg else msg[4:].strip()
        chat_lines.extend(user_block(content, width - 6))
    elif msg.startswith("NovaNode:"):
        chat_lines.extend(think_block(msg[len("NovaNode: "):], width - 6))
    elif msg.startswith("Claude Code:"):
        chat_lines.extend(assistant_block(msg[len("Claude Code: "):], width - 6))
    elif msg.startswith("Codex CLI:"):
        chat_lines.extend(assistant_block(msg[len("Codex CLI: "):], width - 6))
    else:
        chat_lines.extend([f"{DIM}{line}{RESET}" for line in wrap_plain(msg, width - 6)])

chat_h = max(8, height - len(header) - 6)
visible_chat = chat_lines[-chat_h:]

print("\033[3J\033[H\033[2J", end="")
for line in header:
    print(line)
print()

if visible_chat:
    for line in visible_chat:
        print("  " + fit(line, width - 4))
    for _ in range(max(0, chat_h - len(visible_chat))):
        print()
else:
    for _ in range(chat_h):
        print()

print(f"{DIM}{'─' * width}{RESET}")
if providers:
    status = "  ".join(compact_provider(p) for p in providers)
else:
    status = f"{DIM}usage unavailable{RESET}"
print(fit(status, width))
if state_line:
    print(f"{ORANGE}{state_line}{RESET}")
else:
    print(f"{DIM}Ready. Type a prompt and press Enter.{RESET}")
PYEOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  -v|--version)
    echo "$VERSION"
    exit 0
    ;;
  claude|codex|cursor)
    exec_provider "$1"
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1" >&2
    echo "Run 'novanode --help' for usage." >&2
    exit 2
    ;;
esac

active_provider="claude"
usage_data="$(load_usage)"
TRANSCRIPT_FILE=$(mktemp "${TMPDIR:-/tmp}/novanode-chat.XXXXXX")
trap 'rm -f "$TRANSCRIPT_FILE" 2>/dev/null' EXIT

render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"

while true; do
  printf "%s%s%s › " "$GREEN" "$active_provider" "$RESET"
  IFS= read -r input || break

  case "$input" in
    "")
      continue
      ;;
    /q|/quit|exit)
      break
      ;;
    /h|/help)
      printf "NovaNode: opened help for commands.\n" >> "$TRANSCRIPT_FILE"
      usage
      ;;
    /providers)
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
      ;;
    /usage)
      usage_data="$(load_usage)"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
      ;;
    /open)
      printf "NovaNode: opening native %s interface.\n" "$active_provider" >> "$TRANSCRIPT_FILE"
      exec_provider "$active_provider"
      ;;
    /use\ *)
      next="${input#/use }"
      case "$next" in
        claude|codex|cursor)
          active_provider="$next"
          render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
          ;;
        *)
          printf "NovaNode: invalid provider '%s'.\n" "$next" >> "$TRANSCRIPT_FILE"
          echo "Choose claude, codex or cursor."
          ;;
      esac
      ;;
    /*)
      printf "NovaNode: unknown command '%s'.\n" "$input" >> "$TRANSCRIPT_FILE"
      echo "Unknown command. Run /help."
      ;;
    *)
      printf "\r\033[2K"
      printf "You: [%s] %s\n" "$active_provider" "$input" >> "$TRANSCRIPT_FILE"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "NovaNode: $active_provider is thinking..."
      run_prompt "$active_provider" "$input" "$TRANSCRIPT_FILE"
      usage_data="$(load_usage)"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE"
      ;;
  esac
done
