chat_lines = []

CHANGE_ICON = {
    "M": "✎",
    "A": "+",
    "D": "-",
    "R": "→",
    "?": "?",
    "!": "!",
    "U": "⚠",
    "C": "©",
}
VALID_PORC_CHARS = set(" MADRCU?!")

def change_line(text, limit):
    display = text.rstrip()
    if not display:
        return []
    if (
        len(display) >= 3
        and display[2] == " "
        and all(c in VALID_PORC_CHARS for c in display[:2])
        and display[:2].strip()
    ):
        status = display[:2]
        path = display[3:]
        icon = CHANGE_ICON.get(status.strip()[:1], "◆")
        label = f"{icon} {status.strip():<2} {path}"
    else:
        label = f"▸ {display.lstrip()}"
    return [f"{ORANGE}{line}{RESET}" for line in wrap_plain(label, limit)]

def tool_line(text, limit):
    label = f"● {text}"
    return [f"{DIM}{line}{RESET}" for line in wrap_plain(label, limit)]

def picker_line(text, limit):
    trimmed = text.rstrip()
    if not trimmed:
        return [""]
    if trimmed.startswith("Select model"):
        return [f"{BOLD}{GREEN}{trimmed}{RESET}"]
    if trimmed.startswith("Type a number"):
        return [f"{DIM}{line}{RESET}" for line in wrap_plain(trimmed, limit)]
    if trimmed.lstrip().startswith("✔"):
        return [f"{GREEN}{trimmed}{RESET}"]
    return [f"{ORANGE}{trimmed}{RESET}"]

for msg in messages:
    if msg.startswith("You:"):
        content = msg.split("] ", 1)[-1] if "] " in msg else msg[4:].strip()
        chat_lines.extend(user_block(content, width - 6))
    elif msg.startswith("NovaNode-changes:"):
        raw = msg[len("NovaNode-changes:"):]
        if raw.startswith(" "):
            raw = raw[1:]
        chat_lines.extend(change_line(raw, width - 6))
    elif msg.startswith("NovaNode-tool:"):
        content = msg[len("NovaNode-tool:"):].strip()
        chat_lines.extend(tool_line(content, width - 6))
    elif msg.startswith("NovaNode-picker:"):
        content = msg[len("NovaNode-picker:"):]
        if content.startswith(" "):
            content = content[1:]
        chat_lines.extend(picker_line(content, width - 6))
    elif msg.startswith("NovaNode:"):
        chat_lines.extend(think_block(msg[len("NovaNode: "):], width - 6))
    elif msg.startswith("Claude Code:"):
