def status_row(left, right, limit):
    left = left or ""
    right = right or ""
    left_plain = strip_ansi(left)
    right_plain = strip_ansi(right)
    if not left and not right:
        return ""
    if len(left_plain) + len(right_plain) + 1 > limit:
        left = fit(left, max(0, limit - len(right_plain) - 1)).rstrip()
        left_plain = strip_ansi(left)
    gap = max(1, limit - len(left_plain) - len(right_plain))
    return f"{left}{' ' * gap}{right}"

