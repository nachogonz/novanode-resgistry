#!/usr/bin/env bash

VERSION="1.0.4"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NN_USAGE="${SCRIPT_DIR}/nn-usage"
WORKSPACE_DIR="$(pwd)"

ORANGE=$'\033[38;5;208m'
GREEN=$'\033[38;5;82m'
RED=$'\033[38;5;196m'
CYAN=$'\033[38;5;51m'
WHITE=$'\033[38;2;249;249;249m'
GRAY_BG=$'\033[48;5;237m'
DIM=$'\033[38;5;245m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

usage() {
  cat << EOF
NovaNode

AI terminal hub for Claude and Codex.

Usage:
  novanode
  novanode --help
  novanode --version
  novanode claude
  novanode codex

Inside NovaNode:
  /use claude|codex     Select provider
  /model [provider] name  Show or set the model (e.g. /model opus-4.7)
  /open                 Open selected provider CLI
  /usage                Refresh usage summary
  /providers            Show providers
  /quit                 Exit (or press ESC)

When a provider needs approval to edit, reply "y" to approve or "n" to skip.
EOF
}

provider_cmd() {
  case "$1" in
    claude) echo "claude" ;;
    codex) echo "codex" ;;
  esac
}

provider_label() {
  case "$1" in
    claude) echo "Claude Code" ;;
    codex) echo "Codex CLI" ;;
  esac
}

exec_provider() {
  local provider="$1"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi
  exec "$cmd"
}

send_prompt() {
  local provider="$1"
  local prompt="$2"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi
  "$cmd" "$prompt"
}

append_prefixed() {
  local prefix="$1"
  local file="$2"
  if [ ! -s "$file" ]; then
    printf "%s: No response captured.\n" "$prefix"
    return 0
  fi

  while IFS= read -r line; do
    if [ -n "$line" ]; then
      printf "%s: %s\n" "$prefix" "$line"
    fi
  done < "$file"
}

parse_prompt_assets() {
  local prompt="$1"
  local prompt_file="$2"
  local images_file="$3"
  python3 - "$prompt" "$prompt_file" "$images_file" << 'PYEOF'
import os, shlex, sys

prompt, prompt_file, images_file = sys.argv[1:4]
image_exts = (".png", ".jpg", ".jpeg", ".webp", ".gif", ".bmp", ".tiff", ".heic")
image_re = r"(?:~|/)[^\n]*?\.(?:png|jpe?g|webp|gif|bmp|tiff|heic)"

def clean_paste_markers(text):
    return text.replace("\x1b[200~", "").replace("\x1b[201~", "").replace("[200~", "").replace("[201~", "")

def resolve_candidate(raw):
    raw = raw.strip("\"' ")
    for candidate in (raw, raw.replace("\\ ", " ")):
        expanded = os.path.expanduser(candidate)
        if os.path.isfile(expanded):
            return expanded
    return None

def image_paths_from_prompt(text):
    text = clean_paste_markers(text)
    paths = []
    index = 0
    while index < len(text):
        start_candidates = [pos for pos in (text.find("/", index), text.find("~", index)) if pos != -1]
        if not start_candidates:
            break
        start = min(start_candidates)
        best = None
        lower = text.lower()
        for ext in image_exts:
            search = start
            while True:
                end = lower.find(ext, search)
                if end == -1:
                    break
                candidate_end = end + len(ext)
                resolved = resolve_candidate(text[start:candidate_end])
                if resolved:
                    best = (start, candidate_end, resolved)
                    break
                search = end + 1
            if best:
                break
        if best:
            paths.append(((best[0], best[1]), best[2]))
            index = best[1]
        else:
            index = start + 1
    return paths

prompt = clean_paste_markers(prompt)
found = image_paths_from_prompt(prompt)
images = [path for _, path in found]
clean_prompt = prompt
for span, path in reversed(found):
    if span:
        clean_prompt = clean_prompt[:span[0]] + clean_prompt[span[1]:]

clean_prompt = " ".join(clean_prompt.split()).strip()
if images and not clean_prompt:
    clean_prompt = "Please inspect the attached image."

with open(prompt_file, "w") as fh:
    fh.write(clean_prompt or prompt)
with open(images_file, "w") as fh:
    for image in images:
        fh.write(image + "\n")
PYEOF
}

summarize_prompt_for_chat() {
  local prompt="$1"
  python3 - "$prompt" << 'PYEOF'
import os, shlex, sys

prompt = sys.argv[1]
image_exts = (".png", ".jpg", ".jpeg", ".webp", ".gif", ".bmp", ".tiff", ".heic")
image_re = r"(?:~|/)[^\n]*?\.(?:png|jpe?g|webp|gif|bmp|tiff|heic)"

def clean_paste_markers(text):
    return text.replace("\x1b[200~", "").replace("\x1b[201~", "").replace("[200~", "").replace("[201~", "")

def resolve_candidate(raw):
    raw = raw.strip("\"' ")
    for candidate in (raw, raw.replace("\\ ", " ")):
        expanded = os.path.expanduser(candidate)
        if os.path.isfile(expanded):
            return expanded
    return None

def extract(text):
    text = clean_paste_markers(text)
    found = []
    index = 0
    while index < len(text):
        start_candidates = [pos for pos in (text.find("/", index), text.find("~", index)) if pos != -1]
        if not start_candidates:
            break
        start = min(start_candidates)
        best = None
        lower = text.lower()
        for ext in image_exts:
            search = start
            while True:
                end = lower.find(ext, search)
                if end == -1:
                    break
                candidate_end = end + len(ext)
                resolved = resolve_candidate(text[start:candidate_end])
                if resolved:
                    best = (start, candidate_end, resolved)
                    break
                search = end + 1
            if best:
                break
        if best:
            found.append(((best[0], best[1]), best[2]))
            index = best[1]
        else:
            index = start + 1
    return found

prompt = clean_paste_markers(prompt)
found = extract(prompt)
summary = prompt
for span, _ in reversed(found):
    summary = summary[:span[0]] + summary[span[1]:]
summary = " ".join(summary.split()).strip()
if found:
    label = " ".join(f"[Image #{idx}]" for idx, _ in enumerate(found, 1))
    summary = f"{label} {summary}".strip()
print(summary or prompt)
PYEOF
}

display_prompt_input() {
  local prompt="$1"
  python3 - "$prompt" << 'PYEOF'
import os, re, shlex, sys

prompt = sys.argv[1]
image_exts = (".png", ".jpg", ".jpeg", ".webp", ".gif", ".bmp", ".tiff", ".heic")
prompt = prompt.replace("\x1b[200~", "").replace("\x1b[201~", "").replace("[200~", "").replace("[201~", "")
prompt = re.sub(r"[\x00-\x08\x0b-\x1f\x7f-\x9f\ufffd]", "", prompt)
prompt = re.sub(r"^\s*\?+\s*", "", prompt)
prompt = re.sub(r"\[Image #[0-9]+\]\s*", "", prompt)

def looks_like_pending_image_path(value):
    lowered = value.lower()
    return (
        lowered.startswith("/var/folders/")
        or lowered.startswith("/private/var/folders/")
        or lowered.startswith("/private/tmp/")
        or lowered.startswith("/tmp/")
    ) and (
        "temporaryitems" in lowered
        or "tempora" in lowered
        or "nsird_screencaptureui" in lowered
        or "screenshot" in lowered
        or (lowered.startswith("/var/folders/") and "/t/" in lowered)
        or (lowered.startswith("/private/var/folders/") and "/t/" in lowered)
        or any(token in lowered for token in (".png", ".jpg", ".jpeg", ".webp", ".gif", ".heic"))
    )

out = []
last = 0
image_count = 0
index = 0
lower = prompt.lower()
while index < len(prompt):
    start_candidates = [pos for pos in (prompt.find("/", index), prompt.find("~", index)) if pos != -1]
    if not start_candidates:
        break
    start = min(start_candidates)
    best = None
    for ext in image_exts:
        search = start
        while True:
            end = lower.find(ext, search)
            if end == -1:
                break
            candidate_end = end + len(ext)
            candidate = os.path.expanduser(prompt[start:candidate_end].strip("\"' "))
            if os.path.isfile(candidate):
                best = (start, candidate_end)
                break
            search = end + 1
        if best:
            break
    if best:
        out.append(prompt[last:best[0]])
        image_count += 1
        out.append(f"[Image #{image_count}]")
        last = best[1]
        index = best[1]
    elif looks_like_pending_image_path(prompt[start:]):
        out.append(prompt[last:start])
        image_count += 1
        out.append(f"[Image #{image_count}]")
        last = len(prompt)
        index = len(prompt)
    else:
        index = start + 1
out.append(prompt[last:])
display = " ".join("".join(out).split()) if image_count else " ".join(prompt.split())
if not image_count and looks_like_pending_image_path(display):
    display = "[Image #1]"
print(display)
PYEOF
}

color_input_display() {
  local text="$1"
  python3 - "$text" "$CYAN" "$GREEN" "$RESET" << 'PYEOF'
import re, sys

text, cyan, green, reset = sys.argv[1:5]
parts = re.split(r"(\[Image #[0-9]+\])", text)
out = []
for part in parts:
    if re.fullmatch(r"\[Image #[0-9]+\]", part or ""):
        out.append(cyan + part + green)
    else:
        out.append(part)
print("".join(out), end="")
PYEOF
}

compose_prompt_with_attachments() {
  local text="$1"
  local images="$2"
  if [ -n "$images" ]; then
    printf "%s" "$text"
    while IFS= read -r image; do
      [ -n "$image" ] && printf " %s" "$image"
    done <<< "$images"
  else
    printf "%s" "$text"
  fi
}

display_prompt_attachments() {
  local text="$1"
  local images="$2"
  local count=0 labels="" image
  while IFS= read -r image; do
    [ -n "$image" ] || continue
    count=$((count + 1))
    labels="${labels}[Image #${count}] "
  done <<< "$images"
  printf "%s%s" "$labels" "$text"
}

usage_pct_for_provider() {
  local provider="$1"
  awk -F '\t' -v key="$provider" '$1 == key { print $5; exit }' <<< "$usage_data"
}

provider_exhausted() {
  local provider="$1" pct
  pct="$(usage_pct_for_provider "$provider")"
  [[ "$pct" =~ ^[0-9]+([.][0-9]+)?$ ]] && awk -v pct="$pct" 'BEGIN { exit !(pct >= 100) }'
}

choose_default_provider() {
  if provider_exhausted "$active_provider"; then
    case "$active_provider" in
      claude)
        provider_exhausted codex || active_provider="codex"
        ;;
      codex)
        provider_exhausted claude || active_provider="claude"
        ;;
    esac
  fi
}

claude_stream_parser() {
  local transcript="$1"
  python3 -c '
import json, sys
transcript = sys.argv[1]
seen_text = set()
def emit(line):
    with open(transcript, "a") as f:
        f.write(line + "\n")
def short(x):
    if not isinstance(x, str):
        return ""
    x = x.strip()
    return x[:57] + "…" if len(x) > 60 else x
for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        d = json.loads(raw)
    except Exception:
        continue
    t = d.get("type", "")
    if t == "assistant":
        msg = d.get("message", {}) or {}
        for item in (msg.get("content") or []):
            it = item.get("type")
            if it == "tool_use":
                name = item.get("name", "tool")
                inp = item.get("input", {}) or {}
                arg = (
                    inp.get("file_path")
                    or inp.get("path")
                    or inp.get("command")
                    or inp.get("pattern")
                    or inp.get("query")
                    or inp.get("description")
                    or ""
                )
                emit(f"NovaNode-tool: {name}({short(arg)})")
            elif it == "text":
                txt = (item.get("text") or "").strip()
                if txt and txt not in seen_text:
                    seen_text.add(txt)
                    emit(f"Claude Code: {txt}")
    elif t == "result":
        r = (d.get("result") or "").strip()
        if r and r not in seen_text:
            seen_text.add(r)
            emit(f"Claude Code: {r}")
    elif t == "system" and d.get("subtype") == "error":
        msg = d.get("message") or d.get("error") or ""
        if msg:
            emit(f"NovaNode: {msg}")
' "$transcript"
}

codex_stream_parser() {
  local transcript="$1"
  python3 -c '
import sys

transcript = sys.argv[1]
metadata_keys = {
    "workdir", "model", "provider", "approval", "sandbox",
    "reasoning effort", "reasoning summaries", "session id",
}
skip_user_lines = 0
capture_tokens = False
seen_text = set()

def emit(line):
    with open(transcript, "a") as f:
        f.write(line + "\n")

for raw in sys.stdin:
    line = raw.rstrip("\n")
    stripped = line.strip()
    if not stripped:
        continue

    lower = stripped.lower()
    if capture_tokens:
        emit(f"NovaNode-tokens: codex={stripped}")
        capture_tokens = False
        continue
    if lower.startswith("model:"):
        model = stripped.split(":", 1)[1].strip()
        if model:
            emit(f"NovaNode-model: codex={model}")
        continue
    if lower.startswith("tokens used"):
        value = stripped.split(":", 1)[1].strip() if ":" in stripped else ""
        if value:
            emit(f"NovaNode-tokens: codex={value}")
        else:
            capture_tokens = True
        continue
    if (
        stripped == "--------"
        or lower == "codex"
        or lower == "assistant"
        or lower == "user"
        or lower.startswith("reading additional input")
        or lower.startswith("openai codex")
        or any(lower.startswith(f"{key}:") for key in metadata_keys)
    ):
        if lower == "user":
            skip_user_lines = 1
        continue
    if skip_user_lines:
        skip_user_lines -= 1
        continue

    if stripped not in seen_text:
        seen_text.add(stripped)
        emit(f"Codex CLI: {stripped}")
' "$transcript"
}

run_prompt() {
  local provider="$1"
  local prompt="$2"
  local transcript_file="$3"
  local approve="${4:-0}"
  local cmd status prompt_tmp images_tmp image clean_prompt

  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf "NovaNode: %s is not installed or not on PATH.\n" "$cmd" >> "$transcript_file"
    return 127
  fi

  prompt_tmp="$(mktemp "${TMPDIR:-/tmp}/novanode-prompt.XXXXXX")"
  images_tmp="$(mktemp "${TMPDIR:-/tmp}/novanode-images.XXXXXX")"
  parse_prompt_assets "$prompt" "$prompt_tmp" "$images_tmp"
  clean_prompt="$(cat "$prompt_tmp")"

  case "$provider" in
    claude)
      local extra=(--print --verbose --output-format stream-json)
      [ "$approve" -eq 1 ] && extra+=(--permission-mode acceptEdits)
      [ -n "$model_claude" ] && extra+=(--model "$model_claude")
      local attach_dir="" attach_paths="" attach_index=0
      if [ -s "$images_tmp" ]; then
        attach_dir="$(mktemp -d "${TMPDIR:-/tmp}/novanode-attach.XXXXXX")"
        while IFS= read -r image; do
          [ -n "$image" ] || continue
          [ -f "$image" ] || continue
          attach_index=$((attach_index + 1))
          local ext="${image##*.}"
          local staged="${attach_dir}/image_${attach_index}.${ext}"
          cp "$image" "$staged" 2>/dev/null || continue
          attach_paths="${attach_paths}- ${staged}"$'\n'
        done < "$images_tmp"
        if [ -n "$attach_paths" ]; then
          extra+=(--add-dir "$attach_dir")
          clean_prompt="${clean_prompt}"$'\n\n'"The user attached image(s). Use the Read tool on each of these paths to view the images before responding:"$'\n'"${attach_paths}"
        fi
      fi
      "$cmd" "${extra[@]}" "$clean_prompt" 2>/dev/null | claude_stream_parser "$transcript_file"
      status=${PIPESTATUS[0]}
      [ -n "$attach_dir" ] && rm -rf "$attach_dir" 2>/dev/null
      ;;
    codex)
      local extra=(exec --color never)
      [ "$approve" -eq 1 ] && extra+=(--full-auto)
      [ -n "$model_codex" ] && extra+=(--model "$model_codex")
      while IFS= read -r image; do
        [ -n "$image" ] && extra+=(--image "$image")
      done < "$images_tmp"
      "$cmd" "${extra[@]}" "$clean_prompt" 2>&1 | codex_stream_parser "$transcript_file"
      status=${PIPESTATUS[0]}
      ;;
  esac

  rm -f "$prompt_tmp" "$images_tmp" 2>/dev/null

  if [ "$status" -ne 0 ]; then
    printf "NovaNode: %s exited with status %s.\n" "$provider" "$status" >> "$transcript_file"
  fi
  return "$status"
}

needs_approval() {
  local file="$1"
  [ -s "$file" ] || return 1
  tail -n 40 "$file" | grep -qEi "(need|require)s? (permission|approval|you to approve)|please approve|permission to (edit|write|modify|create|change)|approve the (edit|change|permission)|awaiting your approval|allow (me|the edit)"
}

load_usage() {
  if [ ! -x "$NN_USAGE" ]; then
    echo ""
    return 0
  fi
  AI_USAGE_NO_REFRESH_PROMPT=1 "$NN_USAGE" --summary-tsv </dev/null 2>/dev/null || true
}

render_screen() {
  local active="$1"
  local data="$2"
  local transcript_file="$3"
  local state_line="${4:-}"
  local models="${5:-}"
  python3 - "$active" "$data" "$transcript_file" "$state_line" "$VERSION" "$WORKSPACE_DIR" "$models" << 'PYEOF'
import re, shutil, sys, textwrap

active = sys.argv[1]
raw = sys.argv[2]
transcript_file = sys.argv[3]
state_line = sys.argv[4]
script_version = sys.argv[5]
workspace_dir = sys.argv[6]
models_arg = sys.argv[7]

models = {}
for chunk in models_arg.split("|"):
    if "=" in chunk:
        k, v = chunk.split("=", 1)
        models[k.strip()] = v.strip()
size = shutil.get_terminal_size((106, 34))
width = max(80, size.columns)
height = max(24, size.lines)

ORANGE = "\033[38;5;208m"
GREEN = "\033[38;5;82m"
RED = "\033[38;5;196m"
WHITE = "\033[38;2;249;249;249m"
GRAY_BG = "\033[48;5;237m"
DIM = "\033[38;5;245m"
BOLD = "\033[1m"
RESET = "\033[0m"

providers = []

def strip_ansi(text):
    return re.sub(r"\033\[[0-9;]*m", "", text)

def fit(text, limit):
    plain = strip_ansi(text)
    if len(plain) <= limit:
        return text + " " * (limit - len(plain))
    out = []
    visible = 0
    i = 0
    while i < len(text) and visible < limit - 1:
        if text[i] == "\033":
            end = text.find("m", i)
            if end == -1:
                break
            out.append(text[i:end + 1])
            i = end + 1
            continue
        out.append(text[i])
        visible += 1
        i += 1
    out.append("…")
    out.append(RESET)
    return "".join(out)

def fill(text, limit):
    plain = strip_ansi(text)
    return text + " " * max(0, limit - len(plain))

def fmt_pct(value):
    if value in ("", "n/a", "stale"):
        return value or "n/a"
    return f"{value}%"

def pct_number(value):
    try:
        return float(str(value).strip().rstrip("%"))
    except Exception:
        return None

for line in raw.splitlines():
    cols = line.split("\t")
    if len(cols) < 11:
        continue
    key, command, version, p1, used1, left1, reset1, p2, used2, left2, reset2 = cols[:11]
    providers.append({
        "key": key,
        "command": command,
        "name": {"claude": "Claude Code", "codex": "Codex CLI"}.get(key, key),
        "version": f"v{version}" if version != "n/a" else "not detected",
        "p1": p1,
        "used1": used1,
        "left1": left1,
        "reset1": reset1,
        "p2": p2,
        "used2": used2,
        "left2": left2,
        "reset2": reset2,
    })

selected = next((p for p in providers if p["key"] == active), providers[0] if providers else None)
providers_sorted = sorted(providers, key=lambda p: 0 if p["key"] == active else 1)

messages = []
try:
    with open(transcript_file) as fh:
        messages = [line.rstrip("\n") for line in fh if line.strip()]
except Exception:
    pass

for msg in messages:
    if msg.startswith("NovaNode-model:"):
        payload = msg[len("NovaNode-model:"):].strip()
        if "=" in payload:
            key, value = payload.split("=", 1)
            key = key.strip()
            value = value.strip()
            if key and value and not models.get(key):
                models[key] = value

token_status = ""
for msg in messages:
    if msg.startswith("NovaNode-tokens:"):
        payload = msg[len("NovaNode-tokens:"):].strip()
        if "=" in payload:
            key, value = payload.split("=", 1)
            key = key.strip()
            value = value.strip()
            if key and value:
                token_status = f"{key} tokens used {value}"

def compact_provider(provider):
    if not provider:
        return f"{DIM}usage unavailable{RESET}"
    selected_mark = "●" if provider["key"] == active else "○"
    used = pct_number(provider["used1"])
    exhausted = used is not None and used >= 100
    tone = RED if exhausted else (GREEN if provider["key"] == active else DIM)
    model = models.get(provider["key"], "") or "default"
    stat = fmt_pct(provider["used1"])
    parts = [provider["key"]]
    if model and model != stat:
        parts.append(model)
    parts.append(stat)
    return f"{tone}{selected_mark} {' '.join(parts)}{RESET}"

def header_usage(provider):
    if not provider:
        return f"{DIM}usage unavailable{RESET}"
    return (
        f"{GREEN if provider['key'] == active else DIM}"
        f"{provider['key']} {provider['version']}{RESET}"
        f"{DIM} · {provider['p1']} {fmt_pct(provider['left1'])} left"
        f" · {provider['p2']} {fmt_pct(provider['left2'])} left{RESET}"
    )

def wrap_plain(text, limit):
    if not text:
        return [""]
    return textwrap.wrap(text, width=max(8, limit)) or [""]

def user_block(text, limit):
    out = []
    for line in wrap_plain(text, limit - 2):
        pad = max(0, limit - 2 - len(line))
        out.append(f"{GRAY_BG}{WHITE} {line}{' ' * pad} {RESET}")
    return out

def assistant_block(text, limit):
    wrapped = wrap_plain(text, limit - 2)
    out = []
    for index, line in enumerate(wrapped):
        prefix = "• " if index == 0 else "  "
        out.append(f"{GREEN}{prefix}{line}{RESET}")
    return out

def think_block(text, limit):
    return [f"{ORANGE}{line}{RESET}" for line in wrap_plain(text, limit)]

header_inner = width - 4
left_w = max(32, min(44, (header_inner - 3) // 2))
right_w = header_inner - left_w - 3
title = f" NovaNode · Terminal · v{script_version} "

def box_top_line():
    return f"{ORANGE}╭─{title}{'─' * max(0, header_inner - len(title))}╮{RESET}"

def box_bottom_line():
    return f"{ORANGE}╰{'─' * (header_inner + 2)}╯{RESET}"

def wrap_block(lines, width_limit):
    out = []
    for line in lines:
        out.extend(wrap_plain(line, width_limit))
    return out

left_lines = wrap_block(
    [
        f"{BOLD}{WHITE}NovaNode{RESET}",
        f"{GREEN}Chat stays here; providers run in-house.{RESET}",
        f"{DIM}Workspace {workspace_dir}{RESET}",
        f"{DIM}{selected['key'] if selected else 'claude'} {selected['version'] if selected else 'n/a'} · {script_version}{RESET}",
    ],
    left_w,
)
right_lines = wrap_block(
    [
        f"{BOLD}{GREEN}Pick a provider. See usage first.{RESET}",
        f"{DIM}/use claude · /use codex · /open{RESET}",
        f"{DIM}/model <name> · /usage · /quit{RESET}",
        f"{GREEN}Approve edits with y/n when asked.{RESET}",
    ],
    right_w,
)

header_rows = max(len(left_lines), len(right_lines))
header = [box_top_line()]
for index in range(header_rows):
    left_text = left_lines[index] if index < len(left_lines) else ""
    right_text = right_lines[index] if index < len(right_lines) else ""
    header.append(
        f"{ORANGE}│{RESET} {fill(left_text, left_w)} {ORANGE}│{RESET} {fill(right_text, right_w)} {ORANGE}│{RESET}"
    )
header.append(box_bottom_line())

chat_lines = []

CHANGE_ICON = {
    "M": "✎",
    "A": "+",
    "D": "-",
    "R": "→",
    "?": "?",
    "!": "!",
    "U": "⚠",
    "C": "©",
}
VALID_PORC_CHARS = set(" MADRCU?!")

def change_line(text, limit):
    display = text.rstrip()
    if not display:
        return []
    if (
        len(display) >= 3
        and display[2] == " "
        and all(c in VALID_PORC_CHARS for c in display[:2])
        and display[:2].strip()
    ):
        status = display[:2]
        path = display[3:]
        icon = CHANGE_ICON.get(status.strip()[:1], "◆")
        label = f"{icon} {status.strip():<2} {path}"
    else:
        label = f"▸ {display.lstrip()}"
    return [f"{ORANGE}{line}{RESET}" for line in wrap_plain(label, limit)]

def tool_line(text, limit):
    label = f"● {text}"
    return [f"{DIM}{line}{RESET}" for line in wrap_plain(label, limit)]

def picker_line(text, limit):
    trimmed = text.rstrip()
    if not trimmed:
        return [""]
    if trimmed.startswith("Select model"):
        return [f"{BOLD}{GREEN}{trimmed}{RESET}"]
    if trimmed.startswith("Type a number"):
        return [f"{DIM}{line}{RESET}" for line in wrap_plain(trimmed, limit)]
    if trimmed.lstrip().startswith("✔"):
        return [f"{GREEN}{trimmed}{RESET}"]
    return [f"{ORANGE}{trimmed}{RESET}"]

for msg in messages:
    if msg.startswith("You:"):
        content = msg.split("] ", 1)[-1] if "] " in msg else msg[4:].strip()
        chat_lines.extend(user_block(content, width - 6))
    elif msg.startswith("NovaNode-changes:"):
        raw = msg[len("NovaNode-changes:"):]
        if raw.startswith(" "):
            raw = raw[1:]
        chat_lines.extend(change_line(raw, width - 6))
    elif msg.startswith("NovaNode-tool:"):
        content = msg[len("NovaNode-tool:"):].strip()
        chat_lines.extend(tool_line(content, width - 6))
    elif msg.startswith("NovaNode-picker:"):
        content = msg[len("NovaNode-picker:"):]
        if content.startswith(" "):
            content = content[1:]
        chat_lines.extend(picker_line(content, width - 6))
    elif msg.startswith("NovaNode:"):
        chat_lines.extend(think_block(msg[len("NovaNode: "):], width - 6))
    elif msg.startswith("Claude Code:"):
        chat_lines.extend(assistant_block(msg[len("Claude Code: "):], width - 6))
    elif msg.startswith("Codex CLI:"):
        chat_lines.extend(assistant_block(msg[len("Codex CLI: "):], width - 6))
    elif msg.startswith("NovaNode-model:") or msg.startswith("NovaNode-tokens:"):
        continue
    else:
        chat_lines.extend([f"{DIM}{line}{RESET}" for line in wrap_plain(msg, width - 6)])

chat_h = max(6, height - len(header) - 7)
visible_chat = chat_lines[-chat_h:]

sys.stdout.write("\033[H\033[2J")
for line in header:
    print(line)
print()

for line in visible_chat:
    print("  " + fit(line, width - 4))
for _ in range(max(0, chat_h - len(visible_chat))):
    print()

border = f"{ORANGE}{'─' * width}{RESET}"

def status_row(left, right, limit):
    left = left or ""
    right = right or ""
    left_plain = strip_ansi(left)
    right_plain = strip_ansi(right)
    if not left and not right:
        return ""
    if len(left_plain) + len(right_plain) + 1 > limit:
        left = fit(left, max(0, limit - len(right_plain) - 1)).rstrip()
        left_plain = strip_ansi(left)
    gap = max(1, limit - len(left_plain) - len(right_plain))
    return f"{left}{' ' * gap}{right}"

row_content = f"{GREEN}›{RESET} "
status_left = f"{GREEN}{state_line}{RESET}" if state_line else ""
status_right = ""

if providers:
    prov_status = "   ".join(compact_provider(p) for p in providers_sorted)
else:
    prov_status = f"{DIM}usage unavailable{RESET}"

print(fit(status_row(status_left, status_right, width), width))
print(border)
print(fit(row_content, width))
print(border)
token_footer = f"{DIM}{token_status}{RESET}" if token_status else ""
sys.stdout.write(fit(status_row(prov_status, token_footer, width), width))

if state_line:
    sys.stdout.write("\033[?25l")
else:
    sys.stdout.write("\r\033[2A\033[2C\033[?25h")
sys.stdout.flush()
PYEOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  -v|--version)
    echo "$VERSION"
    exit 0
    ;;
  claude|codex)
    exec_provider "$1"
    ;;
  "")
    ;;
  *)
    echo "Unknown option: $1" >&2
    echo "Run 'novanode --help' for usage." >&2
    exit 2
    ;;
esac

active_provider="claude"
default_model_claude="${NOVANODE_DEFAULT_MODEL_CLAUDE:-sonnet}"
default_model_codex="${NOVANODE_DEFAULT_MODEL_CODEX:-gpt-5.5}"
model_claude="${NOVANODE_MODEL_CLAUDE:-}"
model_codex="${NOVANODE_MODEL_CODEX:-}"
last_prompt=""
awaiting_approval=0
pending_prompt=""
awaiting_model=0
model_picker_provider=""
model_picker_options=()
usage_data="$(load_usage)"
choose_default_provider

show_model_picker() {
  local provider="$1"
  local current="" opt id desc marker i
  local -a opts
  case "$provider" in
    claude)
      current="$model_claude"
      opts=(
        "default|Use claude CLI default"
        "sonnet|Sonnet — balanced everyday choice"
        "opus|Opus — most capable for complex work"
        "haiku|Haiku — fastest for quick answers"
      )
      ;;
    codex)
      current="$model_codex"
      opts=(
        "default|Use codex CLI default"
        "gpt-5.5|GPT-5.5"
        "gpt-5-codex|GPT-5 Codex"
        "gpt-5|GPT-5"
      )
      ;;
  esac
  awaiting_model=1
  model_picker_provider="$provider"
  model_picker_options=("${opts[@]}")
  {
    printf "NovaNode-picker: Select model for %s\n" "$provider"
    i=1
    for opt in "${opts[@]}"; do
      id="${opt%%|*}"
      desc="${opt#*|}"
      if { [ -z "$current" ] && [ "$id" = "default" ]; } || [ "$id" = "$current" ]; then
        marker="✔ "
      else
        marker="  "
      fi
      printf "NovaNode-picker: %s%d. %s — %s\n" "$marker" "$i" "$id" "$desc"
      i=$((i + 1))
    done
    printf "NovaNode-picker: Type a number and press Enter · anything else to cancel.\n"
  } >> "$TRANSCRIPT_FILE"
}

models_arg() {
  printf "claude=%s|codex=%s" \
    "${model_claude:-$default_model_claude}" \
    "${model_codex:-$default_model_codex}"
}

enter_live_screen() {
  if [ -t 1 ]; then
    printf "\033[?1049h\033[?2004l\033[H\033[?25h"
  fi
}

leave_live_screen() {
  if [ -t 1 ]; then
    printf "\033[?25h\033[?2004l\033[?1049l"
  else
    printf "\033[?25h\033[?2004l"
  fi
}

TRANSCRIPT_FILE=$(mktemp "${TMPDIR:-/tmp}/novanode-chat.XXXXXX")
trap 'rm -f "$TRANSCRIPT_FILE" 2>/dev/null; leave_live_screen' EXIT

snapshot_git() {
  command -v git >/dev/null 2>&1 || return 0
  git -C "$WORKSPACE_DIR" status --porcelain 2>/dev/null | LC_ALL=C sort
}

diff_snapshot() {
  local before="$1" after="$2"
  [ "$before" = "$after" ] && return 0
  diff <(printf "%s\n" "$before") <(printf "%s\n" "$after") 2>/dev/null \
    | awk '/^> /{ sub(/^> /, ""); print }'
}

kill_process_tree() {
  local pid="$1"
  local child
  for child in $(pgrep -P "$pid" 2>/dev/null); do
    kill_process_tree "$child"
  done
  kill -TERM "$pid" 2>/dev/null
}

run_with_activity() {
  local provider="$1"
  local prompt="$2"
  local transcript_file="$3"
  local approve="$4"
  local before_snap
  before_snap="$(snapshot_git)"

  ( run_prompt "$provider" "$prompt" "$transcript_file" "$approve" < /dev/null ) &
  local run_pid=$!

  (
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    local prev_snap="$before_snap"
    local curr_snap new
    while kill -0 "$run_pid" 2>/dev/null; do
      if [ $((i % 3)) -eq 0 ]; then
        curr_snap="$(snapshot_git)"
        if [ -n "$curr_snap" ] && [ "$curr_snap" != "$prev_snap" ]; then
          new="$(diff_snapshot "$prev_snap" "$curr_snap")"
          if [ -n "$new" ]; then
            while IFS= read -r line; do
              [ -n "$line" ] && printf "NovaNode-changes: %s\n" "$line" >> "$transcript_file"
            done <<< "$new"
          fi
          prev_snap="$curr_snap"
        fi
      fi
      local frame="${frames[i % ${#frames[@]}]}"
      render_screen "$provider" "$usage_data" "$transcript_file" "$frame $provider is working… (esc to cancel)" "$(models_arg)"
      i=$((i + 1))
      sleep 0.15
    done
  ) &
  local anim_pid=$!

  local cancelled=0
  local key
  while kill -0 "$run_pid" 2>/dev/null; do
    if IFS= read -rsn1 -t 1 key 2>/dev/null; then
      if [ "$key" = $'\e' ]; then
        cancelled=1
        printf "NovaNode: run cancelled (ESC). Provider process terminated.\n" >> "$transcript_file"
        kill_process_tree "$run_pid"
        break
      fi
    fi
  done

  kill "$anim_pid" 2>/dev/null
  wait "$anim_pid" 2>/dev/null
  wait "$run_pid" 2>/dev/null
  local status=$?

  local after_snap
  after_snap="$(snapshot_git)"
  local final_diff
  final_diff="$(diff_snapshot "$before_snap" "$after_snap")"
  if [ -n "$final_diff" ]; then
    local stat_line
    stat_line="$(git -C "$WORKSPACE_DIR" diff --shortstat 2>/dev/null)"
    [ -n "$stat_line" ] && printf "NovaNode-changes: %s\n" "$stat_line" >> "$transcript_file"
  fi
  [ "$cancelled" -eq 1 ] && return 130
  return "$status"
}

read_prompt() {
  if [ ! -t 0 ] || [ ! -t 1 ]; then
    IFS= read -r REPLY
    return $?
  fi
  printf "\r\033[2K%s› %s" "$GREEN" "$RESET"
  local reply=""
  if IFS= read -er reply; then
    REPLY="$reply"
    return 0
  fi
  REPLY=""
  return 1
}

enter_live_screen
render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"

handle_prompt() {
  local prompt_text="$1"
  local approve="${2:-0}"
  last_prompt="$prompt_text"
  render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "⠋ $active_provider is starting…" "$(models_arg)"
  run_with_activity "$active_provider" "$prompt_text" "$TRANSCRIPT_FILE" "$approve"
  local run_status=$?
  usage_data="$(load_usage)"
  choose_default_provider
  if [ "$run_status" -ne 130 ] && [ "$approve" -eq 0 ] && needs_approval "$TRANSCRIPT_FILE"; then
    awaiting_approval=1
    pending_prompt="$prompt_text"
    printf "NovaNode: The provider is asking for approval. Reply y to approve and retry, or n to skip.\n" >> "$TRANSCRIPT_FILE"
  fi
  render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
}

while true; do
  read_prompt || break
  input="$REPLY"

  if [ "$awaiting_model" -eq 1 ]; then
    awaiting_model=0
    picker_count="${#model_picker_options[@]}"
    if [[ "$input" =~ ^[0-9]+$ ]] && [ "$input" -ge 1 ] && [ "$input" -le "$picker_count" ]; then
      chosen="${model_picker_options[input-1]}"
      chosen_id="${chosen%%|*}"
      if [ "$chosen_id" = "default" ]; then
        new_model=""
      else
        new_model="$chosen_id"
      fi
      case "$model_picker_provider" in
        claude) model_claude="$new_model" ;;
        codex)  model_codex="$new_model" ;;
      esac
      printf "NovaNode: %s model set to %s.\n" "$model_picker_provider" "${new_model:-default}" >> "$TRANSCRIPT_FILE"
    else
      printf "NovaNode: model selection cancelled.\n" >> "$TRANSCRIPT_FILE"
    fi
    model_picker_provider=""
    model_picker_options=()
    render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
    continue
  fi

  if [ "$awaiting_approval" -eq 1 ]; then
    case "$input" in
      y|Y|yes|YES)
        awaiting_approval=0
        printf "You: [%s] (y) approve\n" "$active_provider" >> "$TRANSCRIPT_FILE"
        handle_prompt "$pending_prompt" 1
        pending_prompt=""
        continue
        ;;
      n|N|no|NO|skip|"")
        awaiting_approval=0
        pending_prompt=""
        printf "You: [%s] (n) skip\n" "$active_provider" >> "$TRANSCRIPT_FILE"
        render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
        continue
        ;;
      *)
        awaiting_approval=0
        pending_prompt=""
        ;;
    esac
  fi

  case "$input" in
    "")
      continue
      ;;
    /q|/quit|exit)
      break
      ;;
    /h|/help)
      printf "NovaNode: opened help for commands.\n" >> "$TRANSCRIPT_FILE"
      usage
      ;;
    /providers)
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /usage)
      usage_data="$(load_usage)"
      choose_default_provider
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /model)
      show_model_picker "$active_provider"
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /model\ *)
      model_args="${input#/model }"
      read -r -a model_tokens <<< "$model_args"
      case "${model_tokens[0]}" in
        claude|codex)
          target_provider="${model_tokens[0]}"
          new_model="${model_tokens[*]:1}"
          ;;
        *)
          target_provider="$active_provider"
          new_model="$model_args"
          ;;
      esac
      if [ -z "$new_model" ]; then
        show_model_picker "$target_provider"
      else
        case "$target_provider" in
          claude) model_claude="$new_model" ;;
          codex)  model_codex="$new_model" ;;
        esac
        printf "NovaNode: %s model set to %s.\n" "$target_provider" "$new_model" >> "$TRANSCRIPT_FILE"
      fi
      render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
      ;;
    /open)
      printf "NovaNode: opening native %s interface.\n" "$active_provider" >> "$TRANSCRIPT_FILE"
      exec_provider "$active_provider"
      ;;
    /use\ *)
      next="${input#/use }"
      case "$next" in
        claude|codex)
          active_provider="$next"
          render_screen "$active_provider" "$usage_data" "$TRANSCRIPT_FILE" "" "$(models_arg)"
          ;;
        *)
          printf "NovaNode: invalid provider '%s'.\n" "$next" >> "$TRANSCRIPT_FILE"
          echo "Choose claude or codex."
          ;;
      esac
      ;;
    /*)
      printf "NovaNode: unknown command '%s'.\n" "$input" >> "$TRANSCRIPT_FILE"
      echo "Unknown command. Run /help."
      ;;
    *)
      display_input="$(summarize_prompt_for_chat "$input")"
      printf "\r\033[2K"
      printf "You: [%s] %s\n" "$active_provider" "$display_input" >> "$TRANSCRIPT_FILE"
      handle_prompt "$input" 0
      ;;
  esac
done
