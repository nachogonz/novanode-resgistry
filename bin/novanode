#!/usr/bin/env bash

VERSION="1.0.4"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NN_USAGE="${SCRIPT_DIR}/nn-usage"
WORKSPACE_DIR="$(pwd)"

ORANGE=$'\033[38;5;208m'
GREEN=$'\033[38;5;82m'
RED=$'\033[38;5;196m'
CYAN=$'\033[38;5;51m'
WHITE=$'\033[38;2;249;249;249m'
GRAY_BG=$'\033[48;5;237m'
DIM=$'\033[38;5;245m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

usage() {
  cat << EOF
NovaNode

AI terminal hub for Claude, Codex, and Cursor.

Usage:
  novanode
  novanode --help
  novanode --version
  novanode claude
  novanode codex
  novanode cursor

Inside NovaNode:
  /claude /codex /cursor  Select provider
  /model [provider] name  Show or set the model (e.g. /model opus-4.7)
  /open                 Open selected provider CLI
  /usage                Refresh usage summary
  /providers            Show providers
  /quit                 Exit (or press ESC)

When a provider needs approval to edit, reply "y" to approve or "n" to skip.
EOF
}

provider_cmd() {
  case "$1" in
    claude) echo "claude" ;;
    codex) echo "codex" ;;
    cursor) echo "cursor-agent" ;;
  esac
}

provider_label() {
  case "$1" in
    claude) echo "Claude Code" ;;
    codex) echo "Codex CLI" ;;
    cursor) echo "Cursor Agent" ;;
  esac
}

exec_provider() {
  local provider="$1"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi
  exec "$cmd"
}

send_prompt() {
  local provider="$1"
  local prompt="$2"
  local cmd
  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "NovaNode: ${cmd} is not installed or not on PATH." >&2
    return 127
  fi
  "$cmd" "$prompt"
}

append_prefixed() {
  local prefix="$1"
  local file="$2"
  if [ ! -s "$file" ]; then
    printf "%s: No response captured.\n" "$prefix"
    return 0
  fi

  while IFS= read -r line; do
    if [ -n "$line" ]; then
      printf "%s: %s\n" "$prefix" "$line"
    fi
  done < "$file"
}

parse_prompt_assets() {
  local prompt="$1"
  local prompt_file="$2"
  local images_file="$3"
  python3 - "$prompt" "$prompt_file" "$images_file" << 'PYEOF'
import os, re, sys

prompt, prompt_file, images_file = sys.argv[1:4]

IMAGE_PATH_RE = re.compile(
    r"(?:^|(?<=\s))(?P<path>(?:~|/)[^\s\\]*(?:\\.[^\s\\]*)*\.(?:png|jpe?g|webp|gif|bmp|tiff|heic))",
    re.IGNORECASE,
)

def clean_paste_markers(text):
    return text.replace("\x1b[200~", "").replace("\x1b[201~", "").replace("[200~", "").replace("[201~", "")

def resolve_candidate(raw):
    raw = raw.strip("\"' ")
    # Strip macOS drag-paste backslash-escapes for ANY special char (space, parens,
    # apostrophe, ampersand, ...) — the shell-style escape is `\` + char.
    unescaped = re.sub(r"\\(.)", r"\1", raw)
    for candidate in (raw, unescaped):
        expanded = os.path.expanduser(candidate)
        if os.path.isfile(expanded):
            return expanded
    return None

prompt = clean_paste_markers(prompt)

# Strip every path that looks like an image (shape-based match) regardless
# of file existence — the chat UI already displayed them as [Image #N] chips
# so leaving the raw path in the prompt would be confusing to the model.
images = []
result_parts = []
last = 0
for match in IMAGE_PATH_RE.finditer(prompt):
    result_parts.append(prompt[last:match.start("path")])
    resolved = resolve_candidate(match.group("path"))
    if resolved:
        images.append(resolved)
    last = match.end("path")
result_parts.append(prompt[last:])
clean_prompt = " ".join("".join(result_parts).split()).strip()
if images and not clean_prompt:
    clean_prompt = "Please inspect the attached image."

with open(prompt_file, "w") as fh:
    fh.write(clean_prompt or prompt)
with open(images_file, "w") as fh:
    for image in images:
        fh.write(image + "\n")
PYEOF
}

summarize_prompt_for_chat() {
  local prompt="$1"
  python3 - "$prompt" << 'PYEOF'
import os, re, shlex, sys

prompt = sys.argv[1]
image_exts = (".png", ".jpg", ".jpeg", ".webp", ".gif", ".bmp", ".tiff", ".heic")
image_re = r"(?:~|/)[^\n]*?\.(?:png|jpe?g|webp|gif|bmp|tiff|heic)"

def clean_paste_markers(text):
    return text.replace("\x1b[200~", "").replace("\x1b[201~", "").replace("[200~", "").replace("[201~", "")

def resolve_candidate(raw):
    raw = raw.strip("\"' ")
    # Strip macOS drag-paste backslash-escapes for ANY special char (space, parens,
    # apostrophe, ampersand, ...) — the shell-style escape is `\` + char.
    unescaped = re.sub(r"\\(.)", r"\1", raw)
    for candidate in (raw, unescaped):
        expanded = os.path.expanduser(candidate)
        if os.path.isfile(expanded):
            return expanded
    return None

def extract(text):
    text = clean_paste_markers(text)
    found = []
    index = 0
    while index < len(text):
        start_candidates = [pos for pos in (text.find("/", index), text.find("~", index)) if pos != -1]
        if not start_candidates:
            break
        start = min(start_candidates)
        best = None
        lower = text.lower()
        for ext in image_exts:
            search = start
            while True:
                end = lower.find(ext, search)
                if end == -1:
                    break
                candidate_end = end + len(ext)
                resolved = resolve_candidate(text[start:candidate_end])
                if resolved:
                    best = (start, candidate_end, resolved)
                    break
                search = end + 1
            if best:
                break
        if best:
            found.append(((best[0], best[1]), best[2]))
            index = best[1]
        else:
            index = start + 1
    return found

prompt = clean_paste_markers(prompt)
found = extract(prompt)
summary = prompt
for span, _ in reversed(found):
    summary = summary[:span[0]] + summary[span[1]:]
summary = " ".join(summary.split()).strip()
if found:
    label = " ".join(f"[Image #{idx}]" for idx, _ in enumerate(found, 1))
    summary = f"{label} {summary}".strip()
print(summary or prompt)
PYEOF
}

display_prompt_input() {
  local prompt="$1"
  python3 - "$prompt" << 'PYEOF'
import os, re, shlex, sys

prompt = sys.argv[1]
image_exts = (".png", ".jpg", ".jpeg", ".webp", ".gif", ".bmp", ".tiff", ".heic")
prompt = prompt.replace("\x1b[200~", "").replace("\x1b[201~", "").replace("[200~", "").replace("[201~", "")
prompt = re.sub(r"[\x00-\x08\x0b-\x1f\x7f-\x9f\ufffd]", "", prompt)
prompt = re.sub(r"^\s*\?+\s*", "", prompt)
prompt = re.sub(r"\[Image #[0-9]+\]\s*", "", prompt)

def looks_like_pending_image_path(value):
    lowered = value.lower()
    return (
        lowered.startswith("/var/folders/")
        or lowered.startswith("/private/var/folders/")
        or lowered.startswith("/private/tmp/")
        or lowered.startswith("/tmp/")
    ) and (
        "temporaryitems" in lowered
        or "tempora" in lowered
        or "nsird_screencaptureui" in lowered
        or "screenshot" in lowered
        or (lowered.startswith("/var/folders/") and "/t/" in lowered)
        or (lowered.startswith("/private/var/folders/") and "/t/" in lowered)
        or any(token in lowered for token in (".png", ".jpg", ".jpeg", ".webp", ".gif", ".heic"))
    )

out = []
last = 0
image_count = 0
index = 0
lower = prompt.lower()
while index < len(prompt):
    start_candidates = [pos for pos in (prompt.find("/", index), prompt.find("~", index)) if pos != -1]
    if not start_candidates:
        break
    start = min(start_candidates)
    best = None
    for ext in image_exts:
        search = start
        while True:
            end = lower.find(ext, search)
            if end == -1:
                break
            candidate_end = end + len(ext)
            candidate = os.path.expanduser(prompt[start:candidate_end].strip("\"' "))
            if os.path.isfile(candidate):
                best = (start, candidate_end)
                break
            search = end + 1
        if best:
            break
    if best:
        out.append(prompt[last:best[0]])
        image_count += 1
        out.append(f"[Image #{image_count}]")
        last = best[1]
        index = best[1]
    elif looks_like_pending_image_path(prompt[start:]):
        out.append(prompt[last:start])
        image_count += 1
        out.append(f"[Image #{image_count}]")
        last = len(prompt)
        index = len(prompt)
    else:
        index = start + 1
out.append(prompt[last:])
display = " ".join("".join(out).split()) if image_count else " ".join(prompt.split())
if not image_count and looks_like_pending_image_path(display):
    display = "[Image #1]"
print(display)
PYEOF
}

color_input_display() {
  local text="$1"
  python3 - "$text" "$CYAN" "$GREEN" "$RESET" << 'PYEOF'
import re, sys

text, cyan, green, reset = sys.argv[1:5]
parts = re.split(r"(\[Image #[0-9]+\])", text)
out = []
for part in parts:
    if re.fullmatch(r"\[Image #[0-9]+\]", part or ""):
        out.append(cyan + part + green)
    else:
        out.append(part)
print("".join(out), end="")
PYEOF
}

compose_prompt_with_attachments() {
  local text="$1"
  local images="$2"
  if [ -n "$images" ]; then
    printf "%s" "$text"
    while IFS= read -r image; do
      [ -n "$image" ] && printf " %s" "$image"
    done <<< "$images"
  else
    printf "%s" "$text"
  fi
}

display_prompt_attachments() {
  local text="$1"
  local images="$2"
  local count=0 labels="" image
  while IFS= read -r image; do
    [ -n "$image" ] || continue
    count=$((count + 1))
    labels="${labels}[Image #${count}] "
  done <<< "$images"
  printf "%s%s" "$labels" "$text"
}

usage_pct_for_provider() {
  local provider="$1"
  awk -F '\t' -v key="$provider" '$1 == key { print $5; exit }' <<< "$usage_data"
}

provider_exhausted() {
  local provider="$1" pct
  pct="$(usage_pct_for_provider "$provider")"
  [[ "$pct" =~ ^[0-9]+([.][0-9]+)?$ ]] && awk -v pct="$pct" 'BEGIN { exit !(pct >= 100) }'
}

choose_default_provider() {
  if provider_exhausted "$active_provider"; then
    case "$active_provider" in
      claude)
        if ! provider_exhausted codex; then
          active_provider="codex"
        elif ! provider_exhausted cursor; then
          active_provider="cursor"
        fi
        ;;
      codex)
        if ! provider_exhausted claude; then
          active_provider="claude"
        elif ! provider_exhausted cursor; then
          active_provider="cursor"
        fi
        ;;
      cursor)
        if ! provider_exhausted claude; then
          active_provider="claude"
        elif ! provider_exhausted codex; then
          active_provider="codex"
        fi
        ;;
    esac
  fi
}

claude_stream_parser() {
  local transcript="$1"
  python3 -c '
import json, sys
transcript = sys.argv[1]
seen_text = set()
def emit(line):
    with open(transcript, "a") as f:
        f.write(line + "\n")
def short(x):
    if not isinstance(x, str):
        return ""
    x = x.strip()
    return x[:57] + "…" if len(x) > 60 else x
for raw in sys.stdin:
    raw = raw.strip()
    if not raw:
        continue
    try:
        d = json.loads(raw)
    except Exception:
        continue
    t = d.get("type", "")
    if t == "assistant":
        msg = d.get("message", {}) or {}
        for item in (msg.get("content") or []):
            it = item.get("type")
            if it == "tool_use":
                name = item.get("name", "tool")
                inp = item.get("input", {}) or {}
                arg = (
                    inp.get("file_path")
                    or inp.get("path")
                    or inp.get("command")
                    or inp.get("pattern")
                    or inp.get("query")
                    or inp.get("description")
                    or ""
                )
                emit(f"NovaNode-tool: {name}({short(arg)})")
            elif it == "text":
                txt = (item.get("text") or "").strip()
                if txt and txt not in seen_text:
                    seen_text.add(txt)
                    emit(f"Claude Code: {txt}")
    elif t == "result":
        r = (d.get("result") or "").strip()
        if r and r not in seen_text:
            seen_text.add(r)
            emit(f"Claude Code: {r}")
    elif t == "system" and d.get("subtype") == "error":
        msg = d.get("message") or d.get("error") or ""
        if msg:
            emit(f"NovaNode: {msg}")
' "$transcript"
}

codex_stream_parser() {
  local transcript="$1"
  python3 -c '
import sys

transcript = sys.argv[1]
metadata_keys = {
    "workdir", "model", "provider", "approval", "sandbox",
    "reasoning effort", "reasoning summaries", "session id",
}
skip_user_lines = 0
capture_tokens = False
seen_text = set()

def emit(line):
    with open(transcript, "a") as f:
        f.write(line + "\n")

for raw in sys.stdin:
    line = raw.rstrip("\n")
    stripped = line.strip()
    if not stripped:
        continue

    lower = stripped.lower()
    if capture_tokens:
        emit(f"NovaNode-tokens: codex={stripped}")
        capture_tokens = False
        continue
    if lower.startswith("model:"):
        model = stripped.split(":", 1)[1].strip()
        if model:
            emit(f"NovaNode-model: codex={model}")
        continue
    if lower.startswith("tokens used"):
        value = stripped.split(":", 1)[1].strip() if ":" in stripped else ""
        if value:
            emit(f"NovaNode-tokens: codex={value}")
        else:
            capture_tokens = True
        continue
    if (
        stripped == "--------"
        or lower == "codex"
        or lower == "assistant"
        or lower == "user"
        or lower.startswith("reading additional input")
        or lower.startswith("openai codex")
        or any(lower.startswith(f"{key}:") for key in metadata_keys)
    ):
        if lower == "user":
            skip_user_lines = 1
        continue
    if skip_user_lines:
        skip_user_lines -= 1
        continue

    if stripped not in seen_text:
        seen_text.add(stripped)
        emit(f"Codex CLI: {stripped}")
' "$transcript"
}

run_prompt() {
  local provider="$1"
  local prompt="$2"
  local transcript_file="$3"
  local approve="${4:-0}"
  local cmd status prompt_tmp images_tmp image clean_prompt

  cmd="$(provider_cmd "$provider")"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    printf "NovaNode: %s is not installed or not on PATH.\n" "$cmd" >> "$transcript_file"
    return 127
  fi

  prompt_tmp="$(mktemp "${TMPDIR:-/tmp}/novanode-prompt.XXXXXX")"
  images_tmp="$(mktemp "${TMPDIR:-/tmp}/novanode-images.XXXXXX")"
  parse_prompt_assets "$prompt" "$prompt_tmp" "$images_tmp"
  clean_prompt="$(cat "$prompt_tmp")"

  case "$provider" in
    claude)
      local extra=(--print --verbose --output-format stream-json)
      [ "$approve" -eq 1 ] && extra+=(--permission-mode acceptEdits)
      [ -n "$model_claude" ] && extra+=(--model "$model_claude")
      local attach_dir="" attach_paths="" attach_index=0
      if [ -s "$images_tmp" ]; then
        # Put attached images INSIDE the workspace so Claude has native read access —
        # no permission prompt required, no --add-dir dance, no --allowedTools flag.
        attach_dir="${WORKSPACE_DIR}/.novanode-attach.$$"
        mkdir -p "$attach_dir" 2>/dev/null || attach_dir=""
        if [ -n "$attach_dir" ]; then
          while IFS= read -r image; do
            [ -n "$image" ] || continue
            [ -f "$image" ] || continue
            attach_index=$((attach_index + 1))
            local ext="${image##*.}"
            local staged="${attach_dir}/image_${attach_index}.${ext}"
            cp "$image" "$staged" 2>/dev/null || continue
            attach_paths="${attach_paths}- ${staged}"$'\n'
          done < "$images_tmp"
          if [ -n "$attach_paths" ]; then
            clean_prompt="${clean_prompt}"$'\n\n'"The user attached image(s). Use the Read tool on each of these paths to view the images before responding:"$'\n'"${attach_paths}"
          fi
        fi
      fi
      "$cmd" "${extra[@]}" "$clean_prompt" 2>/dev/null | claude_stream_parser "$transcript_file"
      status=${PIPESTATUS[0]}
      [ -n "$attach_dir" ] && rm -rf "$attach_dir" 2>/dev/null
      ;;
    codex)
      local extra=(exec --color never)
      [ "$approve" -eq 1 ] && extra+=(--full-auto)
      [ -n "$model_codex" ] && extra+=(--model "$model_codex")
      while IFS= read -r image; do
        [ -n "$image" ] && extra+=(--image "$image")
      done < "$images_tmp"
      "$cmd" "${extra[@]}" "$clean_prompt" 2>&1 | codex_stream_parser "$transcript_file"
      status=${PIPESTATUS[0]}
      ;;
    cursor)
      local extra=(--print --output-format text --trust --auto-review)
      [ "$approve" -eq 1 ] && extra+=(--force)
      [ -n "$model_cursor" ] && extra+=(--model "$model_cursor")
      if [ -s "$images_tmp" ]; then
        clean_prompt="${clean_prompt}"$'\n\n'"The user attached image(s) at these paths. Inspect them before responding:"
        while IFS= read -r image; do
          [ -n "$image" ] && clean_prompt="${clean_prompt}"$'\n'"- ${image}"
        done < "$images_tmp"
      fi
      "$cmd" "${extra[@]}" "$clean_prompt" 2>&1 |
        while IFS= read -r line; do
          [ -n "$line" ] && printf "Cursor Agent: %s\n" "$line" >> "$transcript_file"
        done
      status=${PIPESTATUS[0]}
      ;;
  esac

  rm -f "$prompt_tmp" "$images_tmp" 2>/dev/null

  if [ "$status" -ne 0 ]; then
    printf "NovaNode: %s exited with status %s.\n" "$provider" "$status" >> "$transcript_file"
  fi
  return "$status"
}

needs_approval() {
  local file="$1"
  [ -s "$file" ] || return 1
  tail -n 40 "$file" | grep -qEi "(need|require)s? (permission|approval|you to approve)|please approve|permission to (edit|write|modify|create|change)|approve the (edit|change|permission)|awaiting your approval|allow (me|the edit)"
}

load_usage() {
  if [ ! -x "$NN_USAGE" ]; then
    echo ""
    return 0
  fi
  AI_USAGE_NO_REFRESH_PROMPT=1 "$NN_USAGE" --summary-tsv </dev/null 2>/dev/null || true
}

render_screen() {
  local active="$1"
  local data="$2"
  local transcript_file="$3"
  local state_line="${4:-}"
  local models="${5:-}"
  local input_buffer="${6:-}"
  local input_cursor="${7:-0}"
  local render_mode="${8:-full}"
  # Scrolling is intentionally disabled: always render the latest chat frame.
  local chat_scroll="0"
  python3 - "$active" "$data" "$transcript_file" "$state_line" "$VERSION" "$WORKSPACE_DIR" "$models" "$input_buffer" "$input_cursor" "$chat_scroll" "$render_mode" << 'PYEOF'
import re, shutil, sys, textwrap

active = sys.argv[1]
raw = sys.argv[2]
transcript_file = sys.argv[3]
state_line = sys.argv[4]
script_version = sys.argv[5]
workspace_dir = sys.argv[6]
models_arg = sys.argv[7]

models = {}
for chunk in models_arg.split("|"):
    if "=" in chunk:
        k, v = chunk.split("=", 1)
        models[k.strip()] = v.strip()
size = shutil.get_terminal_size((106, 34))
width = max(80, size.columns)
height = max(24, size.lines)

ORANGE = "\033[38;5;208m"
GREEN = "\033[38;5;82m"
RED = "\033[38;5;196m"
WHITE = "\033[38;2;249;249;249m"
GRAY_BG = "\033[48;5;237m"
DIM = "\033[38;5;245m"
BOLD = "\033[1m"
RESET = "\033[0m"

providers = []

def strip_ansi(text):
    return re.sub(r"\033\[[0-9;]*m", "", text)

def fit(text, limit):
    plain = strip_ansi(text)
    if len(plain) <= limit:
        return text + " " * (limit - len(plain))
    out = []
    visible = 0
    i = 0
    while i < len(text) and visible < limit - 1:
        if text[i] == "\033":
            end = text.find("m", i)
            if end == -1:
                break
            out.append(text[i:end + 1])
            i = end + 1
            continue
        out.append(text[i])
        visible += 1
        i += 1
    out.append("…")
    out.append(RESET)
    return "".join(out)

def fill(text, limit):
    plain = strip_ansi(text)
    return text + " " * max(0, limit - len(plain))

def fmt_pct(value):
    if value in ("", "n/a", "stale"):
        return value or "n/a"
    return f"{value}%"

def pct_number(value):
    try:
        return float(str(value).strip().rstrip("%"))
    except Exception:
        return None

def token_battery(used_value):
    used = pct_number(used_value)
    if used is None:
        return f"{BOLD}{DIM}▱▱ ▱▱ ▱▱ ▱▱ ▱▱{RESET}", "n/a"
    left = max(0.0, min(100.0, 100.0 - used))
    if left <= 0:
        filled = 0
    elif left >= 100:
        filled = 5
    else:
        filled = max(1, min(4, int((left - 1e-9) // 25) + 1))
    charge_tone = RED if left <= 0 else GREEN
    groups = [f"{charge_tone}▰▰" for _ in range(filled)]
    groups.extend(f"{DIM}▱▱" for _ in range(5 - filled))
    # Ten glyphs, grouped into five dense, larger visual blocks.
    meter = f"{BOLD}{' '.join(groups)}{RESET}"
    shown = f"{left:g}%"
    return meter, shown

for line in raw.splitlines():
    cols = line.split("\t")
    if len(cols) < 11:
        continue
    key, command, version, p1, used1, left1, reset1, p2, used2, left2, reset2 = cols[:11]
    providers.append({
        "key": key,
        "command": command,
        "name": {"claude": "Claude Code", "codex": "Codex CLI"}.get(key, key),
        "version": f"v{version}" if version != "n/a" else "not detected",
        "p1": p1,
        "used1": used1,
        "left1": left1,
        "reset1": reset1,
        "p2": p2,
        "used2": used2,
        "left2": left2,
        "reset2": reset2,
    })

selected = next((p for p in providers if p["key"] == active), providers[0] if providers else None)
providers_sorted = sorted(providers, key=lambda p: 0 if p["key"] == active else 1)

messages = []
try:
    with open(transcript_file) as fh:
        messages = [line.rstrip("\n") for line in fh if line.strip()]
except Exception:
    pass

for msg in messages:
    if msg.startswith("NovaNode-model:"):
        payload = msg[len("NovaNode-model:"):].strip()
        if "=" in payload:
            key, value = payload.split("=", 1)
            key = key.strip()
            value = value.strip()
            if key and value and not models.get(key):
                models[key] = value

token_status = ""
for msg in messages:
    if msg.startswith("NovaNode-tokens:"):
        payload = msg[len("NovaNode-tokens:"):].strip()
        if "=" in payload:
            key, value = payload.split("=", 1)
            key = key.strip()
            value = value.strip()
            if key and value:
                token_status = f"{key} tokens used {value}"

def compact_provider(provider):
    if not provider:
        return f"{DIM}usage unavailable{RESET}"
    selected_mark = "●" if provider["key"] == active else "○"
    used = pct_number(provider["used1"])
    exhausted = used is not None and used >= 100
    tone = RED if exhausted else (GREEN if provider["key"] == active else DIM)
    model = models.get(provider["key"], "") or "default"
    meter, remaining = token_battery(provider["used1"])
    parts = [provider["key"]]
    if model:
        parts.append(model)
    return (
        f"{tone}{selected_mark} {' '.join(parts)}{RESET} "
        f"{meter} {DIM}{remaining}{RESET}"
    )

def header_usage(provider):
    if not provider:
        return f"{DIM}usage unavailable{RESET}"
    return (
        f"{GREEN if provider['key'] == active else DIM}"
        f"{provider['key']} {provider['version']}{RESET}"
        f"{DIM} · {provider['p1']} {fmt_pct(provider['left1'])} left"
        f" · {provider['p2']} {fmt_pct(provider['left2'])} left{RESET}"
    )

def wrap_plain(text, limit):
    if not text:
        return [""]
    return textwrap.wrap(text, width=max(8, limit)) or [""]

def user_block(text, limit):
    out = []
    for line in wrap_plain(text, limit - 2):
        pad = max(0, limit - 2 - len(line))
        out.append(f"{GRAY_BG}{WHITE} {line}{' ' * pad} {RESET}")
    return out

def assistant_block(text, limit):
    wrapped = wrap_plain(text, limit - 2)
    out = []
    for index, line in enumerate(wrapped):
        prefix = "• " if index == 0 else "  "
        out.append(f"{GREEN}{prefix}{line}{RESET}")
    return out

def think_block(text, limit):
    return [f"{ORANGE}{line}{RESET}" for line in wrap_plain(text, limit)]

import os as _os

MARK_CROP_RATIO = 85 / 373
WORD_CROP_START = 100 / 373
LOGO_RENDER_WIDTH = 960

def find_logo_path():
    import glob
    candidates = [
        _os.path.expanduser(
            "~/Documents/† NovaNode/∆ NovaApp/clients/nova-app/public/logo.svg"
        ),
        _os.path.expanduser("~/.cache/ai-usage/novanode-logo.png"),
    ]
    candidates.extend(
        glob.glob(
            _os.path.expanduser(
                "~/Documents/*/NovaNode/*/clients/nova-app/public/logo.svg"
            )
        )
    )
    for path in candidates:
        if _os.path.isfile(path):
            return path
    return None

def load_full_logo(path):
    try:
        from PIL import Image
    except ImportError:
        return None

    cache_dir = _os.path.expanduser("~/.cache/ai-usage")
    cache_path = _os.path.join(cache_dir, "novanode-full.png")

    def crop_content(image):
        px = image.load()
        xs, ys = [], []
        for y in range(image.height):
            for x in range(image.width):
                if px[x, y][3] >= 20:
                    xs.append(x)
                    ys.append(y)
        if not xs:
            return image
        return image.crop((min(xs), min(ys), max(xs) + 1, max(ys) + 1))

    try:
        src_mtime = _os.path.getmtime(path) if _os.path.isfile(path) else 0
        if _os.path.isfile(cache_path) and _os.path.getmtime(cache_path) >= src_mtime:
            return Image.open(cache_path).convert("RGBA")

        if path.lower().endswith(".svg"):
            import shutil as _shutil
            import subprocess
            import tempfile

            rendered = None
            rsvg = _shutil.which("rsvg-convert")
            if rsvg:
                tmp_png = _os.path.join(cache_dir, ".logo-render.png")
                _os.makedirs(cache_dir, exist_ok=True)
                result = subprocess.run(
                    [rsvg, "-w", str(LOGO_RENDER_WIDTH), "-o", tmp_png, path],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                if result.returncode == 0 and _os.path.isfile(tmp_png):
                    rendered = Image.open(tmp_png).convert("RGBA")

            if rendered is None:
                try:
                    import cairosvg
                    from io import BytesIO

                    png = cairosvg.svg2png(
                        url=path,
                        output_width=LOGO_RENDER_WIDTH,
                        output_height=int(LOGO_RENDER_WIDTH * 100.862 / 372.882),
                    )
                    rendered = Image.open(BytesIO(png)).convert("RGBA")
                except Exception:
                    rendered = None

            if rendered is None:
                tmp = tempfile.mkdtemp(prefix="ai-usage-logo-")
                subprocess.run(
                    ["qlmanage", "-t", "-s", "1200", "-o", tmp, path],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                    check=False,
                )
                png_path = _os.path.join(tmp, _os.path.basename(path) + ".png")
                if not _os.path.isfile(png_path):
                    return None
                rendered = crop_content(Image.open(png_path).convert("RGBA"))

            img = rendered
        else:
            img = Image.open(path).convert("RGBA")

        _os.makedirs(cache_dir, exist_ok=True)
        img.save(cache_path, format="PNG")
        return img
    except Exception:
        try:
            if _os.path.isfile(cache_path):
                return Image.open(cache_path).convert("RGBA")
        except Exception:
            pass
    return None

def split_logo_parts(full):
    mark_w = min(full.width, max(1, int(full.width * MARK_CROP_RATIO) + 2))
    word_x = min(full.width - 1, int(full.width * WORD_CROP_START))
    mark = full.crop((0, 0, mark_w, full.height))
    word = full.crop((word_x, 0, full.width, full.height))

    def crop_content(image):
        px = image.load()
        xs, ys = [], []
        for y in range(image.height):
            for x in range(image.width):
                if px[x, y][3] >= 20:
                    xs.append(x)
                    ys.append(y)
        if not xs:
            return image
        return image.crop((min(xs), min(ys), max(xs) + 1, max(ys) + 1))

    return crop_content(mark), crop_content(word)

def image_to_halfblocks(image, width, height):
    from PIL import Image

    img = image.copy()
    img.thumbnail((width, height * 2), Image.Resampling.LANCZOS)
    w, h = img.size
    if h % 2:
        padded = Image.new("RGBA", (w, h + 1), (0, 0, 0, 0))
        padded.paste(img, (0, 0))
        img = padded
        h += 1

    px = img.load()
    lines = []
    for y in range(0, h, 2):
        parts = []
        for x in range(w):
            top = px[x, y]
            bot = px[x, y + 1]
            if top[3] < 20 and bot[3] < 20:
                parts.append(" ")
                continue
            if bot[3] < 20:
                parts.append(
                    f"\033[38;2;{top[0]};{top[1]};{top[2]}m▀{RESET}"
                )
            elif top[3] < 20:
                parts.append(
                    f"\033[48;2;{bot[0]};{bot[1]};{bot[2]}m▀{RESET}"
                )
            else:
                parts.append(
                    f"\033[38;2;{top[0]};{top[1]};{top[2]}m"
                    f"\033[48;2;{bot[0]};{bot[1]};{bot[2]}m▀{RESET}"
                )
        lines.append("".join(parts))

    return [line.rstrip() for line in lines if strip_ansi(line).strip()]

def text_shaded_white(r, g, b):
    lum = (r + g + b) / 3
    if lum < 120:
        return None
    hi = int(228 + (lum / 255) * 27)
    return (
        int(min(255, hi + (r - lum) // 6)),
        int(min(255, hi + (g - lum) // 6)),
        int(min(255, hi + (b - lum) // 6)),
    )

def isolate_text_pixels(image):
    from PIL import Image

    img = image.copy()
    px = img.load()
    for y in range(img.height):
        for x in range(img.width):
            r, g, b, a = px[x, y]
            if a < 20:
                px[x, y] = (0, 0, 0, 0)
                continue
            if r >= 180 and g >= 180 and b >= 180:
                continue
            px[x, y] = (0, 0, 0, 0)
    return img

def image_to_braille(image, char_w, char_h, whiten=True):
    from PIL import Image

    braille_base = 0x2800
    dot_map = [
        (0, 0, 0),
        (0, 1, 1),
        (0, 2, 2),
        (0, 3, 6),
        (1, 0, 3),
        (1, 1, 4),
        (1, 2, 5),
        (1, 3, 7),
    ]

    img = image.copy()
    if whiten:
        img = isolate_text_pixels(img)
    img.thumbnail((char_w * 2, char_h * 4), Image.Resampling.LANCZOS)
    w, h = img.size
    pad_h = (4 - h % 4) % 4
    if pad_h:
        padded = Image.new("RGBA", (w, h + pad_h), (0, 0, 0, 0))
        padded.paste(img, (0, 0))
        img = padded
        h += pad_h

    px = img.load()
    lines = []
    for y in range(0, h, 4):
        row = []
        for x in range(0, w, 2):
            bits = 0
            colors = []
            for dx, dy, bit in dot_map:
                xx, yy = x + dx, y + dy
                if xx < w and yy < h:
                    pixel = px[xx, yy]
                    if pixel[3] >= 20:
                        if whiten:
                            shaded = text_shaded_white(*pixel[:3])
                            if shaded is None:
                                continue
                            bits |= 1 << bit
                            colors.append(shaded)
                        else:
                            bits |= 1 << bit
                            colors.append(pixel[:3])
            if bits:
                r = int(sum(c[0] for c in colors) // len(colors))
                g = int(sum(c[1] for c in colors) // len(colors))
                b = int(sum(c[2] for c in colors) // len(colors))
                row.append(f"\033[38;2;{r};{g};{b}m{chr(braille_base + bits)}{RESET}")
            else:
                row.append(" ")
        if strip_ansi("".join(row)).strip():
            lines.append("".join(row))

    return lines

def merge_logo_rows(left_lines_in, right_lines_in, gap=2, align="bottom"):
    height = len(left_lines_in)

    def pad(lines):
        if align == "bottom":
            return [""] * max(0, height - len(lines)) + lines
        top = (height - len(lines)) // 2
        bottom = height - len(lines) - top
        return [""] * top + lines + [""] * bottom

    left = left_lines_in
    right = pad(right_lines_in)
    spacer = " " * gap
    merged = []
    for left_line, right_line in zip(left, right):
        if strip_ansi(right_line).strip():
            merged.append(f"{left_line}{spacer}{right_line}".rstrip())
        else:
            merged.append(left_line)
    return merged

def wordmark_size(panel_w, mark_w=11, gap=2):
    budget = max(0, panel_w - mark_w - gap)
    if budget < 18:
        return 0, 0
    if budget < 26:
        return min(budget, 22), 3
    if budget < 34:
        return min(budget, 28), 4
    return min(budget, 32), 4

def clip_logo_line(text, max_w):
    if len(strip_ansi(text)) <= max_w:
        return text
    out = []
    visible = 0
    i = 0
    while i < len(text):
        if text[i] == "\033":
            end = text.find("m", i)
            if end == -1:
                break
            out.append(text[i : end + 1])
            i = end + 1
            continue
        if visible >= max_w:
            break
        out.append(text[i])
        visible += 1
        i += 1
    out.append(RESET)
    return "".join(out)

def render_mark_lines(path, mark_w=11, mark_h=5):
    try:
        from PIL import Image  # noqa: F401
    except ImportError:
        return []
    full = load_full_logo(path)
    if full is None:
        return []
    mark, _word = split_logo_parts(full)
    return image_to_halfblocks(mark, mark_w, mark_h)

def render_wordmark_lines(path, char_w, char_h):
    try:
        from PIL import Image  # noqa: F401
    except ImportError:
        return []
    full = load_full_logo(path)
    if full is None:
        return []
    _mark, word = split_logo_parts(full)
    return image_to_braille(word, char_w, char_h, whiten=True)

def compose_logo(path, panel_w):
    mark_w, mark_h, gap = 11, 5, 2
    mark = render_mark_lines(path, mark_w, mark_h)
    if not mark:
        return []
    mark_width = max(len(strip_ansi(line)) for line in mark)
    char_w, char_h = wordmark_size(panel_w, mark_width, gap)
    if char_w > 0 and char_h > 0:
        word = render_wordmark_lines(path, char_w, char_h)
        if word:
            merged = merge_logo_rows(mark, word, gap=gap, align="bottom")
            return [clip_logo_line(line, panel_w) for line in merged]
    word_line = f"{BOLD}{WHITE}NovaNode{RESET}"
    out = list(mark)
    out[-1] = clip_logo_line(f"{out[-1]}  {word_line}", panel_w)
    return [clip_logo_line(line, panel_w) for line in out]

def cached_logo_lines(panel_w):
    logo_path = find_logo_path()
    if not logo_path:
        return None
    try:
        src_mtime = int(_os.path.getmtime(logo_path))
    except Exception:
        src_mtime = 0
    cache_dir = _os.path.expanduser("~/.cache/novanode")
    try:
        _os.makedirs(cache_dir, exist_ok=True)
    except Exception:
        pass
    cache_file = _os.path.join(cache_dir, f"logo-v2-w{panel_w}-{src_mtime}.txt")
    if _os.path.isfile(cache_file):
        try:
            with open(cache_file) as fh:
                cached = fh.read().split("\n")
            if cached and cached[-1] == "":
                cached = cached[:-1]
            if cached:
                return cached
        except Exception:
            pass
    logo = compose_logo(logo_path, panel_w)
    if logo:
        try:
            with open(cache_file, "w") as fh:
                fh.write("\n".join(logo))
        except Exception:
            pass
    return logo

def cached_hero_lines(char_w, char_h=4):
    logo_path = find_logo_path()
    if not logo_path:
        return []
    try:
        src_mtime = int(_os.path.getmtime(logo_path))
    except Exception:
        src_mtime = 0
    cache_dir = _os.path.expanduser("~/.cache/novanode")
    cache_file = _os.path.join(
        cache_dir, f"hero-v1-w{char_w}-h{char_h}-{src_mtime}.txt"
    )
    try:
        _os.makedirs(cache_dir, exist_ok=True)
        if _os.path.isfile(cache_file):
            with open(cache_file) as fh:
                cached = fh.read().splitlines()
            if cached:
                return cached
    except Exception:
        pass
    hero = render_wordmark_lines(logo_path, char_w, char_h)
    if hero:
        try:
            with open(cache_file, "w") as fh:
                fh.write("\n".join(hero))
        except Exception:
            pass
    return hero

